@{
    ViewData["Title"] = "Inicio";
}

@section Styles {
<style>
    .hero-landing {
      background: var(--dark-900); min-height: 92vh;
      display: flex; align-items: center;
      position: relative; overflow: hidden; padding: 5rem 2rem;
    }
    .hero-grid-bg {
      position: absolute; inset: 0; pointer-events: none;
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(192,57,43,0.05) 59px, rgba(192,57,43,0.05) 60px),
        repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(192,57,43,0.05) 59px, rgba(192,57,43,0.05) 60px);
    }
    .hero-glow {
      position: absolute; width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(192,57,43,0.1) 0%, transparent 70%);
      top: -100px; left: -100px; pointer-events: none;
    }
    .hero-landing-inner { max-width: 620px; margin: 0 auto; width: 100%; position: relative; z-index: 2; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.6rem;
      font-family: var(--font-mono); font-size: 0.68rem;
      color: var(--gray-400); letter-spacing: 1.5px; margin-bottom: 1.5rem;
      animation: fadeUp .6s ease both;
    }
    .eyebrow-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--red-500);
      animation: pulse-dot 2s ease infinite;
    }
    @@keyframes pulse-dot { 0%,100% { opacity:1;transform:scale(1); } 50% { opacity:.5;transform:scale(.75); } }
    .hero-landing-title {
      font-family: var(--font-display); font-size: clamp(3.5rem,7vw,6.5rem);
      color: var(--white); line-height: .95; letter-spacing: 2px; margin-bottom: 1.5rem;
      animation: fadeUp .65s ease .1s both;
    }
    .title-stroke { -webkit-text-stroke: 2px var(--red-500); color: transparent; }
    .hero-landing-desc { color: var(--gray-400); font-size: 1rem; line-height: 1.75; max-width: 480px; margin-bottom: 2.25rem; animation: fadeUp .65s ease .2s both; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; animation: fadeUp .65s ease .3s both; }
    .hero-numbers { display: flex; align-items: center; animation: fadeUp .65s ease .4s both; }
    .hn-item { display: flex; flex-direction: column; padding: 0 1.75rem; }
    .hn-item:first-child { padding-left: 0; }
    .hn-val { font-family: var(--font-display); font-size: 2rem; color: var(--red-400); line-height: 1; }
    .hn-label { font-size: .68rem; color: var(--gray-500); font-family: var(--font-mono); margin-top: .2rem; }
    .hn-sep { width: 1px; height: 36px; background: var(--dark-600); }
    .hero-side-deco { position: absolute; right: 8%; top: 50%; transform: translateY(-50%); width: 240px; height: 400px; display: flex; align-items: center; justify-content: center; }
    .deco-bottle { position: relative; animation: float 4s ease-in-out infinite; }
    .bottle-cap { width: 52px; height: 28px; background: linear-gradient(180deg,var(--red-500),var(--red-700)); border-radius: 8px 8px 0 0; margin: 0 auto; }
    .bottle-body { width: 90px; height: 200px; background: linear-gradient(160deg,rgba(192,57,43,.9),rgba(100,10,10,.95)); border-radius: 12px 12px 18px 18px; position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,.1); box-shadow: 0 20px 60px rgba(0,0,0,.5); }
    .bottle-label { position: absolute; inset: 30px 10px; background: var(--white); border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; padding: 8px; }
    .bl-logo { font-family: var(--font-display); font-size: 1.4rem; color: var(--red-600); letter-spacing: 2px; line-height: 1; }
    .bl-name { font-size: .55rem; font-weight: 700; color: var(--gray-800); text-align: center; line-height: 1.3; }
    .bl-vol  { font-family: var(--font-mono); font-size: .5rem; color: var(--gray-500); }
    .bottle-shine { position: absolute; top: 30px; left: 10px; width: 14px; height: 160px; background: linear-gradient(180deg,rgba(255,255,255,.15),transparent); border-radius: 20px; }
    .deco-circle { position: absolute; border-radius: 50%; border: 1px solid rgba(192,57,43,.12); animation: spin-slow linear infinite; }
    .dc1 { width: 220px; height: 220px; animation-duration: 25s; }
    .dc2 { width: 320px; height: 320px; border-style: dashed; animation-duration: 40s; animation-direction: reverse; }
    @@keyframes float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-12px); } }
    .products-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
    .product-card { background: var(--dark-800); border: 1px solid var(--dark-600); border-radius: var(--radius-lg); padding: 1.75rem; position: relative; overflow: hidden; transition: all .25s; }
    .product-card:hover { border-color: var(--red-700); transform: translateY(-4px); box-shadow: var(--shadow-red); }
    .product-card.featured { border-color: var(--red-600); background: linear-gradient(135deg,var(--dark-800),var(--dark-700)); }
    .pc-badge-feat { position: absolute; top: 1rem; right: 1rem; font-family: var(--font-mono); font-size: .58rem; color: var(--red-400); background: rgba(192,57,43,.15); border: 1px solid rgba(192,57,43,.3); padding: .2rem .6rem; border-radius: 999px; }
    .pc-icon { font-size: 2rem; margin-bottom: 1rem; }
    .pc-name { font-family: var(--font-display); font-size: 1.3rem; color: var(--white); letter-spacing: .5px; margin-bottom: .5rem; }
    .pc-desc { font-size: .82rem; color: var(--gray-400); line-height: 1.6; margin-bottom: 1.25rem; }
    .pc-sizes { display: flex; flex-wrap: wrap; gap: .4rem; }
    .pc-size { font-family: var(--font-mono); font-size: .68rem; color: var(--red-400); background: rgba(192,57,43,.08); border: 1px solid rgba(192,57,43,.2); padding: .2rem .5rem; border-radius: var(--radius-sm); }
    .ops-timeline { display: flex; align-items: flex-start; gap: 0; margin: 2.5rem 0 2rem; }
    .ops-step { flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem; }
    .ops-connector { flex-shrink: 0; width: 60px; height: 2px; background: linear-gradient(90deg,var(--red-700),var(--red-500)); margin-top: 2rem; position: relative; }
    .ops-connector::after { content:''; position: absolute; right:-6px; top:-4px; border: 5px solid transparent; border-left: 8px solid var(--red-500); }
    .ops-num { font-family: var(--font-display); font-size: 3rem; color: var(--red-600); line-height: 1; border: 2px solid var(--red-200); border-radius: 50%; width: 72px; height: 72px; display: flex; align-items: center; justify-content: center; background: var(--red-50); }
    .ops-title { font-family: var(--font-display); font-size: 1.15rem; color: var(--gray-900); letter-spacing: .5px; }
    .ops-desc  { font-size: .8rem; color: var(--gray-500); line-height: 1.6; max-width: 180px; }
    .contact-info { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 2rem; }
    .ci-item { display: flex; align-items: flex-start; gap: 1rem; }
    .ci-icon { font-size: 1.1rem; flex-shrink: 0; }
    .ci-label { display: block; font-size: .7rem; color: var(--gray-500); font-family: var(--font-mono); margin-bottom: .15rem; }
    .ci-val   { display: block; font-size: .88rem; color: var(--white); font-weight: 500; }
    @@media (max-width: 1024px) {
      .products-grid { grid-template-columns: repeat(2,1fr); }
      .hero-side-deco { display: none; }
      .ops-timeline { flex-direction: column; align-items: flex-start; }
      .ops-connector { width: 2px; height: 30px; margin: 0 0 0 35px; }
      .ops-connector::after { display: none; }
      .ops-step { flex-direction: row; text-align: left; gap: 1.25rem; }
    }
    @@media (max-width: 640px) {
      .products-grid { grid-template-columns: 1fr; }
      .hero-numbers { flex-wrap: wrap; gap: 1rem; }
      .hn-sep { display: none; }
      .hn-item { padding: 0; }
    }
</style>
}

<!-- ══ HERO ══ -->
<section class="hero-landing" id="inicio">
  <div class="hero-grid-bg"></div>
  <div class="hero-glow"></div>
  <div class="hero-landing-inner">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      Empresa Boliviana · Desde 1998
    </div>
    <h1 class="hero-landing-title">
      El sabor que<br/>
      <span class="title-stroke">refresca</span><br/>
      Bolivia
    </h1>
    <p class="hero-landing-desc">
      Somos una empresa boliviana dedicada a la producción y comercialización
      de bebidas y refrescos de calidad, distribuidos en todo el mercado nacional
      con compromiso, tradición e innovación.
    </p>
    <div class="hero-actions">
      <a href="#quienes" class="btn-primary">Conocer más</a>
      <a href="#contacto" class="btn-ghost">Contáctanos →</a>
    </div>
    <div class="hero-numbers">
      <div class="hn-item">
        <span class="hn-val">25+</span>
        <span class="hn-label">Años en el mercado</span>
      </div>
      <div class="hn-sep"></div>
      <div class="hn-item">
        <span class="hn-val">9</span>
        <span class="hn-label">Departamentos</span>
      </div>
      <div class="hn-sep"></div>
      <div class="hn-item">
        <span class="hn-val">100%</span>
        <span class="hn-label">Producción nacional</span>
      </div>
    </div>
  </div>
  <div class="hero-side-deco" aria-hidden="true">
    <div class="deco-bottle">
      <div class="bottle-cap"></div>
      <div class="bottle-body">
        <div class="bottle-label">
          <span class="bl-logo">RV</span>
          <span class="bl-name">Refresco<br/>del Valle</span>
          <span class="bl-vol">500 ml</span>
        </div>
      </div>
      <div class="bottle-shine"></div>
    </div>
    <div class="deco-circle dc1"></div>
    <div class="deco-circle dc2"></div>
  </div>
</section>

<!-- ══ QUIÉNES SOMOS ══ -->
<section class="section" id="quienes">
  <div class="container">
    <div class="two-col">
      <div class="col-text">
        <div class="section-tag">QUIÉNES SOMOS</div>
        <h2 class="section-title">Tradición boliviana<br/>en cada botella</h2>
        <p class="body-text">
          Refrescos del Valle S.R.L. nació con la misión de proveer bebidas de calidad
          accesibles para todos los bolivianos. Desde nuestra planta principal operamos
          líneas de producción modernas con estándares de calidad en cada lote fabricado.
        </p>
        <p class="body-text mt-1">
          Contamos con sucursales en los principales departamentos del país y una flota
          de distribución propia que garantiza la llegada de nuestros productos frescos
          a cada punto de venta.
        </p>
        <div class="pill-group">
          <span class="pill">🏆 Calidad certificada</span>
          <span class="pill">🌿 Ingredientes naturales</span>
          <span class="pill">🇧🇴 Hecho en Bolivia</span>
        </div>
      </div>
      <div class="col-visual">
        <div class="stats-card">
          <div class="sc-row">
            <div class="sc-item">
              <span class="sc-num">25+</span>
              <span class="sc-label">Años de experiencia</span>
            </div>
            <div class="sc-item">
              <span class="sc-num">9</span>
              <span class="sc-label">Departamentos cubiertos</span>
            </div>
          </div>
          <div class="sc-divider"></div>
          <div class="sc-row">
            <div class="sc-item">
              <span class="sc-num">6</span>
              <span class="sc-label">Líneas de producción</span>
            </div>
            <div class="sc-item">
              <span class="sc-num">100%</span>
              <span class="sc-label">Producción nacional</span>
            </div>
          </div>
          <div class="sc-badge">Flota propia de distribución en todo el territorio boliviano</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ PRODUCTOS ══ -->
<section class="section section-dark" id="productos">
  <div class="container">
    <div class="section-header-centered">
      <div class="section-tag light">NUESTROS PRODUCTOS</div>
      <h2 class="section-title light">Línea de refrescos</h2>
      <p class="section-subdesc">Presentaciones disponibles para todos los gustos y ocasiones</p>
    </div>
    <div class="products-grid">
      <div class="product-card">
        <div class="pc-icon">🍓</div>
        <h3 class="pc-name">Refresco Fresa</h3>
        <p class="pc-desc">Sabor intenso a fresa natural, sin conservantes artificiales.</p>
        <div class="pc-sizes">
          <span class="pc-size">250ml</span><span class="pc-size">500ml</span><span class="pc-size">1L</span>
        </div>
      </div>
      <div class="product-card featured">
        <div class="pc-badge-feat">FAVORITO</div>
        <div class="pc-icon">🍋</div>
        <h3 class="pc-name">Refresco Limón</h3>
        <p class="pc-desc">Refrescante y cítrico, el clásico que nunca falla en el calor boliviano.</p>
        <div class="pc-sizes">
          <span class="pc-size">250ml</span><span class="pc-size">500ml</span><span class="pc-size">1L</span><span class="pc-size">2L</span>
        </div>
      </div>
      <div class="product-card">
        <div class="pc-icon">🍊</div>
        <h3 class="pc-name">Refresco Naranja</h3>
        <p class="pc-desc">Elaborado con concentrado de naranja y vitamina C natural.</p>
        <div class="pc-sizes">
          <span class="pc-size">250ml</span><span class="pc-size">500ml</span><span class="pc-size">1L</span>
        </div>
      </div>
      <div class="product-card">
        <div class="pc-icon">🍇</div>
        <h3 class="pc-name">Refresco Uva</h3>
        <p class="pc-desc">Sabor a uva morada, popular en los valles interandinos de Bolivia.</p>
        <div class="pc-sizes">
          <span class="pc-size">250ml</span><span class="pc-size">500ml</span>
        </div>
      </div>
      <div class="product-card">
        <div class="pc-icon">🌿</div>
        <h3 class="pc-name">Línea Natural</h3>
        <p class="pc-desc">Sin colorantes artificiales, endulzada con stevia boliviana.</p>
        <div class="pc-sizes">
          <span class="pc-size">500ml</span><span class="pc-size">1L</span>
        </div>
      </div>
      <div class="product-card">
        <div class="pc-icon">💧</div>
        <h3 class="pc-name">Agua Purificada</h3>
        <p class="pc-desc">Agua de manantial tratada y purificada en nuestra planta.</p>
        <div class="pc-sizes">
          <span class="pc-size">500ml</span><span class="pc-size">1L</span><span class="pc-size">5L</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ OPERACIONES ══ -->
<section class="section section-alt" id="operaciones">
  <div class="container">
    <div class="section-tag">CÓMO OPERAMOS</div>
    <h2 class="section-title">De la planta a tu mesa</h2>
    <div class="ops-timeline">
      <div class="ops-step">
        <div class="ops-num">01</div>
        <div class="ops-content">
          <h3 class="ops-title">Compra de Ingredientes</h3>
          <p class="ops-desc">Proveedores calificados con contratos de suministro y órdenes de compra trazables.</p>
        </div>
      </div>
      <div class="ops-connector"></div>
      <div class="ops-step">
        <div class="ops-num">02</div>
        <div class="ops-content">
          <h3 class="ops-title">Producción y Calidad</h3>
          <p class="ops-desc">Recetas versionadas, líneas de producción por turno y control de calidad en cada lote.</p>
        </div>
      </div>
      <div class="ops-connector"></div>
      <div class="ops-step">
        <div class="ops-num">03</div>
        <div class="ops-content">
          <h3 class="ops-title">Inventario y Almacén</h3>
          <p class="ops-desc">Stock en tiempo real con movimientos registrados y traslados entre almacenes.</p>
        </div>
      </div>
      <div class="ops-connector"></div>
      <div class="ops-step">
        <div class="ops-num">04</div>
        <div class="ops-content">
          <h3 class="ops-title">Ventas y Distribución</h3>
          <p class="ops-desc">Pedidos, facturación y despacho con flota propia hasta el punto de venta del cliente.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ CONTACTO ══ -->
<section class="section section-dark" id="contacto">
  <div class="container">
    <div class="two-col contact-col">
      <div class="col-text">
        <div class="section-tag light">CONTACTO</div>
        <h2 class="section-title light">Trabajemos<br/>juntos</h2>
        <p class="body-text light">
          ¿Interesado en nuestros productos o en ser distribuidor autorizado?
          Contáctanos y un representante se comunicará contigo.
        </p>
        <div class="contact-info">
          <div class="ci-item">
            <span class="ci-icon">📍</span>
            <div>
              <span class="ci-label">Oficina Central</span>
              <span class="ci-val">Cochabamba, Bolivia</span>
            </div>
          </div>
          <div class="ci-item">
            <span class="ci-icon">📞</span>
            <div>
              <span class="ci-label">Teléfono</span>
              <span class="ci-val">+591 4 123-4567</span>
            </div>
          </div>
          <div class="ci-item">
            <span class="ci-icon">✉️</span>
            <div>
              <span class="ci-label">Correo</span>
              <span class="ci-val">contacto@refrescosdelvalle.bo</span>
            </div>
          </div>
          <div class="ci-item">
            <span class="ci-icon">🕐</span>
            <div>
              <span class="ci-label">Horario</span>
              <span class="ci-val">Lun–Vie · 8:00 – 18:00</span>
            </div>
          </div>
        </div>
      </div>
      <div class="contact-form-wrap">
        <div class="contact-form">
          <h3 class="form-title">Enviar mensaje</h3>
          <div class="form-group">
            <label class="form-label" for="contactNombre">Nombre completo</label>
            <input type="text" id="contactNombre" class="form-input" placeholder="Tu nombre"/>
          </div>
          <div class="form-group">
            <label class="form-label" for="contactEmail">Correo electrónico</label>
            <input type="email" id="contactEmail" class="form-input" placeholder="correo@ejemplo.com"/>
          </div>
          <div class="form-group">
            <label class="form-label" for="contactMsg">Mensaje</label>
            <textarea id="contactMsg" class="form-input form-textarea" placeholder="¿En qué podemos ayudarte?"></textarea>
          </div>
          <button class="btn-primary full-width">Enviar mensaje</button>
        </div>
      </div>
    </div>
  </div>
</section>