@{
    ViewData["Title"] = "Inicio";
    ViewData["NavTransparent"] = true;
}

@section Styles {
<style>
/* ── VARIABLES ── */
:root {
    --negro: #000000;
    --rojo: #C8281E;
    --rojo-suave: rgba(200, 40, 30, 0.1);
    --blanco: #ffffff;
    --gris-50: #fafafa;
    --gris-100: #eef2f0;
    --gris-400: #8f9b9e;
    --gris-600: #5c6a6e;
    --container: 1280px;
    --section-py: 5rem;
    --radius-lg: 1rem;
    --radius-md: 0.5rem;
    --shadow-md: 0 10px 30px -10px rgba(0,0,0,0.1);
    --ease: cubic-bezier(0.4, 0, 0.2, 1);
    --font-mono: 'SF Mono', 'Courier New', monospace;
    --font-display: 'Inter', system-ui, -apple-system, sans-serif;
}

/* ── HERO ── */
.hero {
    min-height: 100vh;
    background: var(--negro);
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
}
.hero-bg-pattern {
    position: absolute; inset: 0;
    background-image:
        radial-gradient(circle at 70% 50%, rgba(200,40,30,0.12) 0%, transparent 55%),
        radial-gradient(circle at 20% 80%, rgba(45,106,47,0.07) 0%, transparent 40%);
    pointer-events: none;
}
.hero-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
}
.hero-inner {
    max-width: var(--container); margin: 0 auto; padding: 0 2rem;
    display: grid; grid-template-columns: 1fr 420px; gap: 4rem;
    align-items: center; width: 100%; position: relative; z-index: 2;
    padding-top: 7rem; padding-bottom: 5rem;
}
.hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-mono); font-size: 0.7rem;
    color: rgba(255,255,255,0.45); letter-spacing: 2px; text-transform: uppercase;
    margin-bottom: 1.5rem;
}
.hero-eyebrow-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--rojo);
    animation: heroPulse 2s ease infinite;
}
@@keyframes heroPulse { 
    0%, 100% {
        opacity: 1;
        transform: scale(1);
    }
    50% {
        opacity: .5;
        transform: scale(.7);
    }
}

.hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 6.5vw, 6rem);
    line-height: 0.95; font-weight: 900;
    color: var(--blanco); letter-spacing: -1px;
    margin-bottom: 1.75rem;
}
.hero-title-stroke {
    -webkit-text-stroke: 2px var(--rojo);
    color: transparent;
    font-style: italic;
}
.hero-desc {
    font-size: 1.05rem; color: rgba(255,255,255,0.55);
    line-height: 1.8; max-width: 520px; margin-bottom: 2.5rem;
}
.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3.5rem; }
.hero-stats { display: flex; gap: 2.5rem; }
.hstat { display: flex; flex-direction: column; }
.hstat-val {
    font-family: var(--font-display); font-size: 2.25rem;
    color: var(--blanco); line-height: 1; font-weight: 700;
}
.hstat-val span { color: var(--rojo); }
.hstat-label {
    font-family: var(--font-mono); font-size: 0.65rem;
    color: rgba(255,255,255,0.35); letter-spacing: 1.5px;
    text-transform: uppercase; margin-top: 0.25rem;
}

/* Botella decorativa */
.hero-visual { display: flex; align-items: center; justify-content: center; position: relative; }
.bottle-wrap {
    position: relative;
    animation: bottleFloat 5s ease-in-out infinite;
}
@@keyframes bottleFloat { 
    0%, 100% {
        transform: translateY(0) rotate(-2deg);
    }
    50% {
        transform: translateY(-18px) rotate(2deg);
    }
}
.bottle-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(200,40,30,0.15);
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    animation: ringSpin linear infinite;
}
.bottle-ring-1 { width: 280px; height: 280px; animation-duration: 20s; }
.bottle-ring-2 { width: 380px; height: 380px; border-style: dashed; animation-duration: 35s; animation-direction: reverse; }
@@keyframes ringSpin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
}
.bottle-svg { width: 160px; height: 320px; position: relative; z-index: 2; filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6)); }

/* Animaciones */
.anim-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.6s forwards;
}
.anim-delay-1 { animation-delay: 0.1s; }
.anim-delay-2 { animation-delay: 0.3s; }
.anim-delay-3 { animation-delay: 0.5s; }
.anim-delay-4 { animation-delay: 0.7s; }
@@keyframes fadeUp {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ── STATS BAR ── */
.stats-bar {
    background: var(--blanco);
    border-top: 3px solid var(--rojo);
    padding: 2.5rem 0;
}
.stats-bar-inner {
    max-width: var(--container); margin: 0 auto; padding: 0 2rem;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 2rem; align-items: center;
}
.stat-item { text-align: center; }
.stat-num {
    font-family: var(--font-display); font-size: 2.75rem;
    color: var(--rojo); font-weight: 900; line-height: 1;
}
.stat-text { font-size: 0.82rem; color: var(--gris-400); margin-top: 0.35rem; }
.stat-sep  { width: 1px; height: 50px; background: var(--gris-100); margin: 0 auto; }

/* ── SECCIÓN HIGHLIGHTS ── */
.highlights { padding: var(--section-py) 0; background: var(--gris-50); }
.container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 2rem;
}
.section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--rojo);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
}
.section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 2rem;
}
.section-title em {
    color: var(--rojo);
    font-style: italic;
}
.highlights-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem; margin-top: 3rem;
}
.hlight-card {
    background: var(--blanco); border: 1px solid var(--gris-100);
    border-radius: var(--radius-lg); padding: 2rem;
    transition: all 0.25s var(--ease);
    position: relative; overflow: hidden;
}
.hlight-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--rojo); transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s var(--ease);
}
.hlight-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
.hlight-card:hover::before { transform: scaleX(1); }
.hlight-icon {
    width: 48px; height: 48px; border-radius: var(--radius-md);
    background: var(--rojo-suave); display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
}
.hlight-icon svg { width: 22px; height: 22px; stroke: var(--rojo); fill: none; stroke-width: 2; }
.hlight-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.6rem; }
.hlight-desc  { font-size: 0.88rem; color: var(--gris-600); line-height: 1.7; }

/* ── FRANJA ROJA CTA ── */
.cta-band {
    background: var(--rojo);
    padding: 4rem 0;
    position: relative; overflow: hidden;
}
.cta-band::before {
    content: 'DEL VALLE';
    position: absolute; right: -2rem; top: 50%; transform: translateY(-50%);
    font-family: var(--font-display); font-size: 14rem; font-weight: 900;
    color: rgba(255,255,255,0.05); line-height: 1; pointer-events: none;
    white-space: nowrap;
}
.cta-band-inner {
    max-width: var(--container); margin: 0 auto; padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
}
.cta-band-title {
    font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.75rem);
    color: var(--blanco); font-weight: 900; line-height: 1.1;
}
.cta-band-sub { color: rgba(255,255,255,0.65); font-size: 1rem; margin-top: 0.5rem; }

/* Botones */
.btn {
    display: inline-block;
    padding: 0.9rem 2rem;
    border-radius: 9999px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s;
    cursor: pointer;
}
.btn-rojo {
    background: var(--rojo);
    color: var(--blanco);
    border: none;
}
.btn-rojo:hover {
    background: #a81f16;
    transform: translateY(-2px);
}
.btn-outline-white {
    background: transparent;
    color: var(--blanco);
    border: 1px solid rgba(255,255,255,0.3);
}
.btn-outline-white:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--blanco);
}

/* ── Responsive ── */
@@media (max-width: 900px) {
    .hero-inner { 
        grid-template-columns: 1fr; 
    }
    .hero-visual { 
        display: none; 
    }
    .highlights-grid { 
        grid-template-columns: repeat(2, 1fr); 
    }
    .stats-bar-inner { 
        grid-template-columns: repeat(2, 1fr); 
        gap: 1rem;
    }
    .stat-sep { 
        display: none; 
    }
    .cta-band-inner { 
        flex-direction: column; 
        text-align: center; 
    }
    .cta-band-inner > div:last-child {
        flex-direction: column;
    }
}

@@media (max-width: 600px) {
    .highlights-grid { 
        grid-template-columns: 1fr; 
    }
    .hero-stats { 
        gap: 1.5rem; 
    }
    .stats-bar-inner { 
        grid-template-columns: 1fr; 
        gap: 1.5rem;
    }
    .hero-cta {
        flex-direction: column;
    }
    .btn {
        text-align: center;
    }
}
</style>
}

<!-- ══ HERO ══ -->
<section class="hero" id="inicio">
    <div class="hero-bg-pattern"></div>
    <div class="hero-grid"></div>
    <div class="hero-inner">
        <div>
            <div class="hero-eyebrow anim-up">
                <span class="hero-eyebrow-dot"></span>
                Empresa Boliviana · Desde 1998
            </div>
            <h1 class="hero-title anim-up anim-delay-1">
                El sabor que<br/>
                <span class="hero-title-stroke">refresca</span><br/>
                Bolivia
            </h1>
            <p class="hero-desc anim-up anim-delay-2">
                Producción y comercialización de bebidas de calidad distribuidas en todo
                el mercado nacional con compromiso, tradición e innovación boliviana.
            </p>
            <div class="hero-cta anim-up anim-delay-3">
                <a href="/Pagina/Productos" class="btn btn-rojo">Ver productos</a>
                <a href="/Pagina/Nosotros"  class="btn btn-outline-white">Nuestra historia</a>
            </div>
            <div class="hero-stats anim-up anim-delay-4">
                <div class="hstat">
                    <span class="hstat-val">25<span>+</span></span>
                    <span class="hstat-label">Años</span>
                </div>
                <div class="hstat">
                    <span class="hstat-val">9</span>
                    <span class="hstat-label">Departamentos</span>
                </div>
                <div class="hstat">
                    <span class="hstat-val">100<span>%</span></span>
                    <span class="hstat-label">Nacional</span>
                </div>
            </div>
        </div>

        <!-- Botella decorativa SVG -->
        <div class="hero-visual" aria-hidden="true">
            <div class="bottle-wrap">
                <div class="bottle-ring bottle-ring-1"></div>
                <div class="bottle-ring bottle-ring-2"></div>
                <svg class="bottle-svg" viewBox="0 0 160 320" xmlns="http://www.w3.org/2000/svg">
                    <!-- Tapa -->
                    <rect x="52" y="0" width="56" height="22" rx="8" fill="#C8281E"/>
                    <rect x="56" y="5" width="48" height="12" rx="4" fill="#9B1C14"/>
                    <!-- Cuello -->
                    <path d="M52 22 Q44 42 38 62 L122 62 Q116 42 108 22 Z" fill="#B5211A"/>
                    <!-- Cuerpo -->
                    <rect x="28" y="62" width="104" height="230" rx="14" fill="#C8281E"/>
                    <!-- Brillo lateral -->
                    <rect x="36" y="75" width="12" height="180" rx="6" fill="rgba(255,255,255,0.12)"/>
                    <!-- Etiqueta -->
                    <rect x="36" y="100" width="88" height="140" rx="8" fill="white"/>
                    <!-- Texto etiqueta -->
                    <text x="80" y="140" text-anchor="middle" font-family="Georgia,serif" font-size="22" font-weight="bold" fill="#C8281E">DEL</text>
                    <text x="80" y="172" text-anchor="middle" font-family="Georgia,serif" font-size="30" font-weight="bold" fill="#C8281E" font-style="italic">Valle</text>
                    <!-- Hoja decorativa -->
                    <ellipse cx="102" cy="180" rx="10" ry="5" fill="#2D6A2F" transform="rotate(-30 102 180)"/>
                    <ellipse cx="110" cy="185" rx="8" ry="4" fill="#2D6A2F" transform="rotate(-15 110 185)"/>
                    <!-- Volumen -->
                    <text x="80" y="222" text-anchor="middle" font-family="monospace" font-size="11" fill="#888">500 ml</text>
                    <!-- Fondo etiqueta banda -->
                    <rect x="36" y="230" width="88" height="10" rx="0" fill="#C8281E" opacity="0.1"/>
                    <!-- Base botella -->
                    <rect x="28" y="280" width="104" height="12" rx="7" fill="#9B1C14"/>
                </svg>
            </div>
        </div>
    </div>
</section>

<!-- ══ BARRA DE ESTADÍSTICAS ══ -->
<section class="stats-bar">
    <div class="stats-bar-inner">
        <div class="stat-item">
            <div class="stat-num">25+</div>
            <div class="stat-text">Años en el mercado boliviano</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
            <div class="stat-num">9</div>
            <div class="stat-text">Departamentos con distribución</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
            <div class="stat-num">6</div>
            <div class="stat-text">Líneas de producción activas</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
            <div class="stat-num">100%</div>
            <div class="stat-text">Producción nacional boliviana</div>
        </div>
    </div>
</section>

<!-- ══ HIGHLIGHTS ══ -->
