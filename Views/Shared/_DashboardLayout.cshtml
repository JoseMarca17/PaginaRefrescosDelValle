<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — Refrescos del Valle</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/dashboard.css"/>
    
    <style>
        :root {
            --sidebar-width: 260px;
        }

        body {
            margin: 0;
            background: var(--dark-900, #0a0303);
        }

        .dashboard-app {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* ══ BARRA LATERAL (SIDEBAR) ══ */
        .dashboard-sidebar {
            width: var(--sidebar-width);
            flex-shrink: 0;
            transition: margin 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s ease;
            z-index: 100;
            background: var(--dark-900, #0a0303);
            height: 100vh;
            position: sticky;
            top: 0;
            border-right: 2px solid var(--red-600, #C8281E); 
            display: flex;
            flex-direction: column;
        }

        /* ══ ÁREA PRINCIPAL ══ */
        .dashboard-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0; 
            transition: padding 0.3s ease, width 0.3s ease;
            padding-left: 1.5rem; /* FIX: era 3rem, causaba el espacio gigante */
        }

        /* ══ BARRA SUPERIOR Y BOTÓN ══ */
        .dashboard-topbar {
            height: 70px;
            background: transparent;
            display: flex;
            align-items: center;
            padding: 1rem 0; 
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .btn-toggle-sidebar {
            background: var(--dark-800, #1a0f0f); 
            border: 1px solid var(--dark-600, #3a2525);
            color: #ffffff; 
            cursor: pointer;
            padding: 0.6rem;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }

        .btn-toggle-sidebar svg {
            stroke: #ffffff; 
        }

        .btn-toggle-sidebar:hover {
            background: var(--red-600, #C8281E);
            border-color: var(--red-500, #d82c20);
            transform: translateY(-2px);
        }

        /* ══ ESTADOS DE VISIBILIDAD ══ */
        
        /* 1. Modo Escritorio (Colapsado) */
        @@media (min-width: 993px) {
            .dashboard-app.sidebar-collapsed .dashboard-sidebar {
                margin-left: -260px !important;
                visibility: hidden;
            }
            .dashboard-app.sidebar-collapsed .dashboard-wrapper {
                padding-left: 1rem; /* FIX: era 1.5rem al colapsar */
            }
        }

        /* 2. Modo Móvil / Tablet */
        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(3px);
            z-index: 95;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        @@media (max-width: 992px) {
            .dashboard-sidebar {
                position: fixed;
                left: 0;
                transform: translateX(-100%);
                margin-left: 0 !important;
            }
            
            .dashboard-wrapper {
                padding-left: 1rem;
                padding-right: 1rem;
            }
            
            .dashboard-app.sidebar-open .dashboard-sidebar {
                transform: translateX(0);
            }
            
            .dashboard-app.sidebar-open .sidebar-overlay {
                opacity: 1;
                visibility: visible;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Usuario";
        var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
        var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
        var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
    }
    
    <div class="dashboard-app" id="dashboardApp">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="dashboard-sidebar">
            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <img src="~/assets/img/LogoRefrescosDelValle.png" alt="Logo" width="40" height="40" onerror="this.src='https://via.placeholder.com/40x40?text=RV'"/>
                    <div>
                        <span class="sidebar-brand">Refrescos</span>
                        <span class="sidebar-brand-sub">del Valle</span>
                    </div>
                </div>
            </div>
            
            <nav class="sidebar-nav" style="flex: 1; overflow-y: auto;">
                <a href="/Dashboard" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <svg viewBox="0 0 24 24" width="20" height="20">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" fill="none"/>
                        <path d="M9 22V12h6v10" stroke="currentColor" fill="none"/>
                    </svg>
                    <span>Dashboard</span>
                </a>
                
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminSeguridad"))
                {
                    <div class="nav-section">
                        <span class="nav-section-title">Seguridad</span>
                        
                        <a href="/Seguridad/RegistrarPersonal" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Seguridad" && ViewContext.RouteData.Values["action"]?.ToString() == "RegistrarPersonal" ? "active" : "")">
                            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="8.5" cy="7" r="4"></circle>
                                <line x1="20" y1="8" x2="20" y2="14"></line>
                                <line x1="23" y1="11" x2="17" y2="11"></line>
                            </svg>
                            <span>Aprovisionar Personal</span>
                        </a>

                        <a href="/Seguridad/Usuarios" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Seguridad" && ViewContext.RouteData.Values["action"]?.ToString() == "Usuarios" ? "active" : "")">
                            <svg viewBox="0 0 24 24" width="20" height="20">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" fill="none"/>
                                <circle cx="12" cy="7" r="4" stroke="currentColor" fill="none"/>
                            </svg>
                            <span>Usuarios</span>
                        </a>
                        <a href="/Seguridad/Roles" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Seguridad" && ViewContext.RouteData.Values["action"]?.ToString() == "Roles" ? "active" : "")">
                            <svg viewBox="0 0 24 24" width="20" height="20">
                                <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" fill="none"/>
                                <path d="M8 7h8M8 12h8M8 17h4" stroke="currentColor"/>
                            </svg>
                            <span>Roles</span>
                        </a>
                        <a href="/Seguridad/Sucursales" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Seguridad" && ViewContext.RouteData.Values["action"]?.ToString() == "Sucursales" ? "active" : "")">
                            <svg viewBox="0 0 24 24" width="20" height="20">
                                <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" fill="none"/>
                                <path d="M2 17l10 5 10-5" stroke="currentColor" fill="none"/>
                                <path d="M2 12l10 5 10-5" stroke="currentColor" fill="none"/>
                            </svg>
                            <span>Sucursales</span>
                        </a>
                        <a href="/Seguridad/Bitacora" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Seguridad" && ViewContext.RouteData.Values["action"]?.ToString() == "Bitacora" ? "active" : "")">
                            <svg viewBox="0 0 24 24" width="20" height="20">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" fill="none"/>
                                <polyline points="14 2 14 8 20 8" stroke="currentColor"/>
                                <line x1="16" y1="13" x2="8" y2="13" stroke="currentColor"/>
                                <line x1="16" y1="17" x2="8" y2="17" stroke="currentColor"/>
                                <polyline points="10 9 9 9 8 9" stroke="currentColor"/>
                            </svg>
                            <span>Bitácora</span>
                        </a>
                    </div>
                }
                
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminProduccion"))
                {
                    <div class="nav-section">
                        <span class="nav-section-title">Producción</span>
                        <a href="/Produccion/Productos" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" fill="none"/><path d="M2 17l10 5 10-5" stroke="currentColor" fill="none"/><path d="M2 12l10 5 10-5" stroke="currentColor" fill="none"/></svg>
                            <span>Productos</span>
                        </a>
                        <a href="/Produccion/Recetas" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" fill="none"/></svg>
                            <span>Recetas</span>
                        </a>
                        <a href="/Produccion/Ordenes" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" fill="none"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor"/></svg>
                            <span>Órdenes de Producción</span>
                        </a>
                    </div>
                }
                
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminInventario"))
                {
                    <div class="nav-section">
                        <span class="nav-section-title">Inventario</span>
                        <a href="/Inventario/IndexInventario" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><polyline points="17 8 21 12 17 16" stroke="currentColor" fill="none"/><polyline points="7 8 3 12 7 16" stroke="currentColor" fill="none"/><line x1="21" y1="12" x2="3" y2="12" stroke="currentColor"/></svg>
                            <span>Index</span>
                        </a>
                        <a href="/Inventario/Almacenes" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" fill="none"/><path d="M8 7h8M8 12h8M8 17h4" stroke="currentColor"/></svg>
                            <span>Almacenes</span>
                        </a>
                        <a href="/Inventario/Movimientos" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M2 12h20M12 2l10 10-10 10" stroke="currentColor" fill="none"/></svg>
                            <span>Movimientos</span>
                        </a>
                        <a href="/Inventario/Stock" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M2 12h20M12 2l10 10-10 10" stroke="currentColor" fill="none"/></svg>
                            <span>Stock</span>
                        </a>
                    </div>
                }
                
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminVentas"))
                {
                    <div class="nav-section">
                        <span class="nav-section-title">Ventas</span>
                        <a href="/Ventas/Pedidos" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" fill="none"/><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor"/><path d="M16 10a4 4 0 01-8 0" stroke="currentColor"/></svg>
                            <span>Pedidos</span>
                        </a>
                        <a href="/Ventas/Clientes" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" fill="none"/><circle cx="9" cy="7" r="4" stroke="currentColor" fill="none"/><path d="M23 21v-2a4 4 0 00-3-3.87" stroke="currentColor"/><path d="M16 3.13a4 4 0 010 7.75" stroke="currentColor"/></svg>
                            <span>Clientes</span>
                        </a>
                        <a href="/Ventas/Facturacion" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" fill="none"/><polyline points="14 2 14 8 20 8" stroke="currentColor"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor"/></svg>
                            <span>Facturación</span>
                        </a>
                    </div>
                }
                
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminCompras"))
                {
                    <div class="nav-section">
                        <span class="nav-section-title">Compras</span>
                        <a href="/Compras/Proveedores" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" fill="none"/><circle cx="12" cy="12" r="3" stroke="currentColor" fill="none"/></svg>
                            <span>Proveedores</span>
                        </a>
                        <a href="/Compras/OrdenesCompra" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" fill="none"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor"/></svg>
                            <span>Órdenes de Compra</span>
                        </a>
                        <a href="/Compras/Logistica" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M1 12h4M9 12h6M17 12h4" stroke="currentColor"/><path d="M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" stroke="currentColor" fill="none"/></svg>
                            <span>Logística</span>
                        </a>
                    </div>
                }
                
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AdminRRHH"))
                {
                    <div class="nav-section">
                        <span class="nav-section-title">RRHH</span>
                        <a href="/RRHH/Empleados" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" fill="none"/><circle cx="12" cy="7" r="4" stroke="currentColor" fill="none"/></svg>
                            <span>Empleados</span>
                        </a>
                        <a href="/RRHH/Planilla" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" fill="none"/><polyline points="14 2 14 8 20 8" stroke="currentColor"/><line x1="12" y1="18" x2="12" y2="12" stroke="currentColor"/><line x1="9" y1="15" x2="15" y2="15" stroke="currentColor"/></svg>
                            <span>Planilla</span>
                        </a>
                        <a href="/RRHH/Asistencia" class="nav-item">
                            <svg viewBox="0 0 24 24" width="20" height="20"><circle cx="12" cy="12" r="10" stroke="currentColor" fill="none"/><polyline points="12 6 12 12 16 14" stroke="currentColor"/></svg>
                            <span>Asistencia</span>
                        </a>
                    </div>
                }
            </nav>
            
            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                        @userInitial
                    </div>
                    <div class="user-details">
                        <span class="user-name">@userName</span>
                        <span class="user-role">@userRole</span>
                    </div>
                </div>
                <a href="/Auth/Logout" class="logout-btn">
                    <svg viewBox="0 0 24 24" width="18" height="18">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" stroke="currentColor" fill="none"/>
                        <polyline points="16 17 21 12 16 7" stroke="currentColor"/>
                        <line x1="21" y1="12" x2="9" y2="12" stroke="currentColor"/>
                    </svg>
                    <span>Cerrar sesión</span>
                </a>
            </div>
        </aside>
        
        <div class="dashboard-wrapper">
            
            <header class="dashboard-topbar">
                <button class="btn-toggle-sidebar" id="btnToggleSidebar">
                    <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
            </header>

            <main class="dashboard-main">
                <div class="dashboard-content">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const app = document.getElementById('dashboardApp');
            const toggleBtn = document.getElementById('btnToggleSidebar');
            const overlay = document.getElementById('sidebarOverlay');

            if (toggleBtn && app) {
                toggleBtn.addEventListener('click', () => {
                    if (window.innerWidth <= 992) {
                        app.classList.toggle('sidebar-open');
                    } else {
                        app.classList.toggle('sidebar-collapsed');
                    }
                });
            }

            if (overlay && app) {
                overlay.addEventListener('click', () => {
                    app.classList.remove('sidebar-open');
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
