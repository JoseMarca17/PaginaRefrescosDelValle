<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] — Refrescos del Valle S.R.L.</title>
  <meta name="description" content="Empresa boliviana dedicada a la producción y comercialización de bebidas y refrescos de calidad desde 1998."/>
  <link rel="icon" href="/assets/img/favicon.ico"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <link rel="stylesheet" href="/css/components.css"/>
  @await RenderSectionAsync("Styles", required: false) <!--No se si cambie esto xd -->  
</head>
<body>
  <!-- ══ HEADER ══ -->
  <nav class="navbar" id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <div class="logo-mark">
          <img src="/assets/img/LogoRefrescosDelValle.png" alt="Logo Refrescos del Valle"
               onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
          <span class="logo-fallback" style="display:none">RV</span>
        </div>
        <div class="brand-text">
          <span class="brand-name">Refrescos del Valle</span>
          <span class="brand-sub">S.R.L. · Bolivia</span>
        </div>
      </a>

      <nav class="nav-links" role="navigation" aria-label="Navegación principal">
        <a href="/#quienes"     class="nav-link">Quiénes Somos</a>
        <a href="/#productos"   class="nav-link">Productos</a>
        <a href="/#operaciones" class="nav-link">Operaciones</a>
        <a href="/#contacto"    class="nav-link">Contacto</a>
      </nav>

      <div class="nav-sep"></div>

      <!-- NO logueado -->
      <a href="/Auth/Login" class="nav-login-btn" aria-label="Iniciar sesión">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
        Iniciar sesión
      </a>

      <!-- Logueado (JS lo muestra) -->
      <div class="nav-user-menu" id="userMenu" style="display:none" role="navigation" aria-label="Menú de usuario">
        <button class="nav-user-trigger" id="userTrigger" aria-haspopup="true" aria-expanded="false">
          <div class="user-avatar" id="userAvatar">
            <span id="userInitials">--</span>
          </div>
          <div class="user-meta">
            <span class="user-name" id="userName">Usuario</span>
            <span class="user-role" id="userRoleLabel">—</span>
          </div>
          <svg class="user-chevron" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div class="user-dropdown" id="userDropdown" role="menu">
          <div class="dropdown-header">
            <div class="dropdown-user-full"  id="ddUserFull">—</div>
            <div class="dropdown-user-email" id="ddUserEmail">—</div>
          </div>
          <div class="dropdown-section">
            <a href="/Seguridad" class="dropdown-item" role="menuitem">
              <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              Ir al sistema
            </a>
            <a href="#" class="dropdown-item" role="menuitem">
              <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Mi perfil
            </a>
          </div>
          <div class="dropdown-section">
            <a href="/Auth/Logout" class="dropdown-item danger" role="menuitem">
              <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Cerrar sesión
            </a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ══ CONTENIDO DE CADA PÁGINA ══ -->
  <main>
    @RenderBody()
  </main>

  <!-- ══ FOOTER ══ -->
  <footer class="footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-brand-col">
        <div class="footer-logo">
          <div class="logo-mark" style="width:38px;height:38px">
            <img src="/assets/img/LogoRefrescosDelValle.png" alt="Logo Refrescos del Valle"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
            <span class="logo-fallback" style="display:none">RV</span>
          </div>
          <div>
            <div class="footer-brand-name">Refrescos del Valle</div>
            <div class="footer-brand-sub">S.R.L. · Bolivia</div>
          </div>
        </div>
        <p class="footer-desc">
          Empresa boliviana dedicada a la producción y comercialización
          de bebidas y refrescos de calidad desde 1998.
        </p>
        <div class="footer-social">
          <a href="#" class="social-btn" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="#" class="social-btn" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="social-btn" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Empresa</span>
        <a href="/#quienes"     class="footer-link">Quiénes Somos</a>
        <a href="/#productos"   class="footer-link">Nuestros Productos</a>
        <a href="/#operaciones" class="footer-link">Cómo Operamos</a>
        <a href="/#contacto"    class="footer-link">Contacto</a>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Sistema Interno</span>
        <a href="/Seguridad"   class="footer-link">Seguridad y Auditoría</a>
        <a href="/Produccion"  class="footer-link">Producción</a>
        <a href="/Inventario"  class="footer-link">Inventario</a>
        <a href="/Ventas"      class="footer-link">Ventas</a>
        <a href="/Compras"     class="footer-link">Compras</a>
        <a href="/RRHH"        class="footer-link">Recursos Humanos</a>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Contacto</span>
        <div class="footer-contact-item">
          <span class="fci-icon">📍</span>
          <div>
            <span class="fci-label">Oficina Central</span>
            <span class="fci-val">Cochabamba, Bolivia</span>
          </div>
        </div>
        <div class="footer-contact-item">
          <span class="fci-icon">📞</span>
          <div>
            <span class="fci-label">Teléfono</span>
            <span class="fci-val">+591 4 123-4567</span>
          </div>
        </div>
        <div class="footer-contact-item">
          <span class="fci-icon">✉️</span>
          <div>
            <span class="fci-label">Correo</span>
            <span class="fci-val">contacto@refrescosdelvalle.bo</span>
          </div>
        </div>
        <div class="footer-contact-item">
          <span class="fci-icon">🕐</span>
          <div>
            <span class="fci-label">Horario</span>
            <span class="fci-val">Lun–Vie · 8:00–18:00</span>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© 2025 Refrescos del Valle S.R.L. · Bolivia · Todos los derechos reservados.</span>
      <div class="footer-bottom-right">
        <a href="#" class="footer-bottom-link">Política de privacidad</a>
        <a href="#" class="footer-bottom-link">Términos de uso</a>
        <span class="footer-mono">SQL Server · ERwin · 3FN</span>
      </div>
    </div>
  </footer>

  <script src="/js/components.js"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>