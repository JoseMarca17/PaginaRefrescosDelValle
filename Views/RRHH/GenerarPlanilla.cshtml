@model RefrescosDelValle.Models.ViewModels.GenerarPlanillaViewModel
@{
    ViewData["Title"] = "Generar Planilla";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modulos/rrhh.css" />
}

<div class="modulo-header">
    <div class="modulo-header-info">
        <a href="@Url.Action("Planilla", "RRHH")" class="btn-volver">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Volver
        </a>
        <h1 class="modulo-title">Generar Planilla</h1>
        <p class="modulo-subtitle">Registra el pago mensual de un empleado</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="GenerarPlanilla" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert-error"></div>

        <div class="form-section">
            <h2 class="form-section-title">Período y Empleado</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="EmpleadoID">Empleado</label>
                    <select asp-for="EmpleadoID" asp-items="ViewBag.Empleados" class="form-control">
                        <option value="">-- Seleccionar empleado --</option>
                    </select>
                    <span asp-validation-for="EmpleadoID" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Mes">Mes</label>
                    <select asp-for="Mes" class="form-control">
                        @{
                            string[] meses = { "", "Enero","Febrero","Marzo","Abril","Mayo","Junio",
                                               "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre" };
                            for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">@meses[m]</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="Mes" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Anio">Año</label>
                    <input asp-for="Anio" class="form-control" type="number" min="2000" max="2100" />
                    <span asp-validation-for="Anio" class="field-error"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">Montos</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="HaberBasico">Haber Básico (Bs.)</label>
                    <input asp-for="HaberBasico" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" id="haberBasico" />
                    <span asp-validation-for="HaberBasico" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Bonos">Bonos (Bs.)</label>
                    <input asp-for="Bonos" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" id="bonos" />
                    <span asp-validation-for="Bonos" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Descuentos">Descuentos (Bs.)</label>
                    <input asp-for="Descuentos" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" id="descuentos" />
                    <span asp-validation-for="Descuentos" class="field-error"></span>
                </div>
            </div>

            <div class="total-preview">
                <span>Total Líquido estimado:</span>
                <strong id="totalLiquido">Bs. 0.00</strong>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">Detalle de Aportes</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="AFP">AFP (Bs.)</label>
                    <input asp-for="AFP" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                    <span asp-validation-for="AFP" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="RC_IVA">RC-IVA (Bs.)</label>
                    <input asp-for="RC_IVA" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                    <span asp-validation-for="RC_IVA" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="CNS">CNS (Bs.)</label>
                    <input asp-for="CNS" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                    <span asp-validation-for="CNS" class="field-error"></span>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="@Url.Action("Planilla", "RRHH")" class="btn-cancelar">Cancelar</a>
            <button type="submit" class="btn-primary-rrhh">Generar Planilla</button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function calcTotal() {
            const haber = parseFloat(document.getElementById('haberBasico').value) || 0;
            const bonos = parseFloat(document.getElementById('bonos').value) || 0;
            const desc  = parseFloat(document.getElementById('descuentos').value) || 0;
            document.getElementById('totalLiquido').textContent = 'Bs. ' + (haber + bonos - desc).toFixed(2);
        }
        ['haberBasico','bonos','descuentos'].forEach(id =>
            document.getElementById(id).addEventListener('input', calcTotal));
    </script>
}
