@model List<RefrescosDelValle.Models.ViewModels.PlanillaViewModel>
@{
    ViewData["Title"] = "Planilla";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int anio = ViewBag.AnioFiltro;
    int mes  = ViewBag.MesFiltro;
    string[] meses = { "", "Enero","Febrero","Marzo","Abril","Mayo","Junio",
                        "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre" };
}

@section Styles {
    <link rel="stylesheet" href="~/css/modulos/rrhh.css" />
}

<div class="modulo-header">
    <div class="modulo-header-info">
        <h1 class="modulo-title">Planilla Salarial</h1>
        <p class="modulo-subtitle">@meses[mes] @anio</p>
    </div>
    <a href="@Url.Action("GenerarPlanilla", "RRHH")" class="btn-primary-rrhh">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Generar Planilla
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-exito">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        @TempData["Exito"]
    </div>
}

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon stat-icon-blue">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">Bs. @((decimal)ViewBag.TotalLiquido).ToString("N2")</span>
            <span class="stat-label">Total líquido</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-green">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">@ViewBag.Pagados</span>
            <span class="stat-label">Pagados</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-yellow">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">@ViewBag.Pendientes</span>
            <span class="stat-label">Pendientes</span>
        </div>
    </div>
</div>

<!-- Filtro mes/año -->
<div class="search-bar">
    <form method="get" asp-action="Planilla">
        <div class="search-input-wrap">
            <select name="mes" class="form-control" style="max-width:160px">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(m == mes ? "selected" : null)">@meses[m]</option>
                }
            </select>
            <select name="anio" class="form-control" style="max-width:120px">
                @for (int a = DateTime.Now.Year; a >= 2020; a--)
                {
                    <option value="@a" selected="@(a == anio ? "selected" : null)">@a</option>
                }
            </select>
            <button type="submit" class="btn-buscar">Filtrar</button>
        </div>
    </form>
</div>

<!-- Tabla -->
<div class="table-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" width="48" height="48" stroke="currentColor" fill="none" stroke-width="1">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            <p>Sin planilla para @meses[mes] @anio</p>
            <a href="@Url.Action("GenerarPlanilla", "RRHH")">Generar planilla</a>
        </div>
    }
    else
    {
        <table class="rrhh-table">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Cargo</th>
                    <th>Haber Básico</th>
                    <th>Bonos</th>
                    <th>Descuentos</th>
                    <th>Total Líquido</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <div class="empleado-info">
                                <div class="empleado-avatar">@p.NombreEmpleado[0]</div>
                                <span class="empleado-nombre">@p.NombreEmpleado</span>
                            </div>
                        </td>
                        <td>@p.Cargo</td>
                        <td>Bs. @p.HaberBasico.ToString("N2")</td>
                        <td>Bs. @p.Bonos.ToString("N2")</td>
                        <td>Bs. @p.Descuentos.ToString("N2")</td>
                        <td><strong>Bs. @p.TotalLiquido.ToString("N2")</strong></td>
                        <td>
                            <span class="badge badge-@(p.Pagado ? "green" : "yellow")">
                                @(p.Pagado ? "Pagado" : "Pendiente")
                            </span>
                        </td>
                        <td>
                            @if (!p.Pagado)
                            {
                                <form method="post" asp-action="MarcarPagado" asp-route-id="@p.PlanillaID" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-accion btn-success" title="Marcar como pagado">
                                        <svg viewBox="0 0 24 24" width="15" height="15" stroke="currentColor" fill="none" stroke-width="2">
                                            <polyline points="20 6 9 17 4 12"/>
                                        </svg>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:0.8rem">@p.FechaPago?.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
