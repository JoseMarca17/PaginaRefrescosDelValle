@model IEnumerable<PaginaRefrescosDelValle.Models.Entities.Cliente>

@{
    ViewData["Title"] = "Listado de Clientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Panel de Gestión de Clientes</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-user-plus"></i> Registrar Nuevo Cliente
        </a>
    </div>

    <div class="card bg-dark text-white border-secondary shadow-lg">
        <div class="card-header border-secondary bg-transparent">
            <h5 class="mb-0 text-info">Clientes Registrados</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead class="thead-light text-secondary">
                        <tr>
                            <th>Nombre Completo</th>
                            <th>Correo Electrónico</th>
                            <th>Categoría</th>
                            <th class="text-center">Operaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@item.Nombre @item.Apellido</div>
                                    </td>
                                    <td>@item.Correo</td>
                                    <td>
                                        <span class="badge @(item.TipoCliente != null ? "bg-primary" : "bg-secondary")">
                                            @(item.TipoCliente?.Descripcion ?? "Sin Categoría")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.ClienteID" class="btn btn-sm btn-outline-info me-2">
                                            <i class="fas fa-eye"></i> Ver
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.ClienteID" class="btn btn-sm btn-outline-warning me-2">
                                            <i class="fas fa-edit"></i> Editar
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ClienteID" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4">
                                    <p class="text-muted mb-0">No hay clientes registrados en el sistema de la planta.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>