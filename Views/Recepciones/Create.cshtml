@model RefrescosDelValle.Models.Entities.RecepcionMercaderium

@{
    ViewData["Title"] = "Nueva Recepción";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dashboard-header">
    <div class="header-left">
        <a href="/Recepciones" class="back-button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Volver a Recepciones
        </a>
        <div>
            <h1 class="dashboard-title">Registrar Recepción</h1>
            <p class="dashboard-subtitle">Ingreso de mercadería al inventario</p>
        </div>
    </div>
    <div class="dashboard-header-right">
        <div class="date-badge">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <rect x="3" y="4" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
        </div>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    
    <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; backdrop-filter: blur(10px);">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1.5rem; color: #C8281E; font-family: 'DM Mono', monospace; font-size: 0.85rem;"></div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
            <div>
                <label asp-for="OrdenCompraId" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Orden de Compra *
                </label>
                <select asp-for="OrdenCompraId" class="form-select-modern" asp-items="ViewBag.OrdenesCompra"
                        style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;">
                    <option value="">Seleccione una orden</option>
                </select>
                <span asp-validation-for="OrdenCompraId" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>

            <div>
                <label for="productoId" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Producto *
                </label>
                <select id="productoId" name="productoId" class="form-select-modern" asp-items="ViewBag.Productos"
                        style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;">
                    <option value="">Seleccione un producto</option>
                </select>
            </div>

            <div>
                <label for="lote" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Número de Lote
                </label>
                <input type="text" id="lote" name="lote" class="form-control-modern" 
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
            </div>

            <div>
                <label for="fechaVencimiento" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Fecha Vencimiento
                </label>
                <input type="date" id="fechaVencimiento" name="fechaVencimiento" class="form-control-modern" 
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
            </div>

            <div>
                <label for="costoUnitario" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Costo Unitario (Bs) *
                </label>
                <input type="number" id="costoUnitario" name="costoUnitario" class="form-control-modern" step="0.01" required
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
            </div>

            <div>
                <label asp-for="CantidadRecibida" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Cantidad Recibida *
                </label>
                <input asp-for="CantidadRecibida" class="form-control-modern" type="number" step="0.01" 
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
                <span asp-validation-for="CantidadRecibida" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>

            <div>
                <label asp-for="AlmacenId" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Almacén *
                </label>
                <select asp-for="AlmacenId" class="form-select-modern" asp-items="ViewBag.Almacenes"
                        style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;">
                    <option value="">Seleccione un almacén</option>
                </select>
                <span asp-validation-for="AlmacenId" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>

            <div>
                <label asp-for="FechaRecepcion" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Fecha Recepción
                </label>
                <input asp-for="FechaRecepcion" class="form-control-modern" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" 
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
                <span asp-validation-for="FechaRecepcion" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>

            <div style="grid-column: span 2;">
                <label asp-for="Observaciones" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Observaciones
                </label>
                <textarea asp-for="Observaciones" rows="3" 
                          style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; resize: vertical;"
                          placeholder="Notas adicionales sobre la recepción..."></textarea>
                <span asp-validation-for="Observaciones" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>
        </div>

        <div style="background: rgba(0, 255, 255, 0.05); border: 1px solid rgba(0, 255, 255, 0.2); border-radius: 12px; padding: 1rem; margin-top: 1.5rem;">
            <div style="display: flex; gap: 0.75rem; align-items: center;">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="#00ffff" fill="none" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span style="color: #00ffff; font-family: 'DM Mono', monospace; font-size: 0.8rem;">
                    <strong>Nota:</strong> El precio de venta se calculará automáticamente (Costo + 30%).
                </span>
            </div>
        </div>
    </div>

    <div style="display: flex; gap: 1rem;">
        <button type="submit" style="background: #C8281E; color: white; padding: 0.8rem 2rem; border-radius: 8px; border: 1px solid #ff4d4d; font-family: 'DM Mono', monospace; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 0.5rem;">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                <polyline points="17 21 17 13 7 13 7 21"/>
                <polyline points="7 3 7 8 15 8"/>
            </svg>
            Registrar Recepción
        </button>
        <a href="/Recepciones" style="background: transparent; color: var(--text-secondary); padding: 0.8rem 2rem; border-radius: 8px; border: 1px solid var(--border-color); text-decoration: none; font-family: 'DM Mono', monospace; font-size: 0.85rem; text-transform: uppercase; transition: all 0.3s; display: flex; align-items: center; gap: 0.5rem;">
            Cancelar
        </a>
    </div>
</form>

<style>
    button[type="submit"]:hover {
        background: #a02018 !important;
        transform: translateY(-2px);
        box-shadow: 0 0 20px rgba(200, 40, 30, 0.5);
    }
    
    .form-control-modern:focus, .form-select-modern:focus {
        outline: none;
        border-color: #C8281E;
        box-shadow: 0 0 10px rgba(200, 40, 30, 0.3);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}