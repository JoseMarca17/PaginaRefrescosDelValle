@model RefrescosDelValle.Models.ViewModels.VerificarOTPViewModel

@{
    ViewData["Title"] = "Verificación en dos pasos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verificación 2FA — Refrescos del Valle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <img src="~/assets/img/LogoRefrescosDelValle.png" alt="Refrescos del Valle"
                     onerror="this.src='https://via.placeholder.com/80x80?text=DV'"/>
            </div>
            
            <h1 class="auth-title">Verificación 2FA</h1>
            <p class="auth-subtitle">
                Ingresa el código de 6 dígitos<br/>
                <span style="font-size: 0.7rem;">Enviamos un código a tu correo electrónico. Expira en 5 minutos.</span>
            </p>

            <form asp-action="Verificar2FA" method="post" class="auth-form" id="otpForm">
                <div asp-validation-summary="All" class="auth-alert auth-alert-danger"
                     style="display:@(ViewData.ModelState.ErrorCount > 0 ? "flex" : "none")"></div>

                <input type="hidden" asp-for="IdUsuario" />

                <div class="form-group">
                    <label class="form-label" style="text-align: center; display: block;">Código de verificación</label>
                    <div class="input-icon-wrapper">
                        <svg class="input-icon" style="left: 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <line x1="9" y1="9" x2="15" y2="15"/>
                            <line x1="15" y1="9" x2="9" y2="15"/>
                        </svg>
                        <input asp-for="Codigo"
                               class="auth-input otp-input"
                               maxlength="6"
                               placeholder="123456"
                               autocomplete="off"
                               id="otpCode" />
                    </div>
                    <span asp-validation-for="Codigo" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="auth-btn auth-btn-success" id="submitBtn">
                        <span>Verificar código</span>
                    </button>
                </div>
            </form>

            <div class="auth-footer">
                <p class="auth-footer-text">
                    ¿No recibiste el código? 
                    <a href="javascript:void(0)" onclick="resendCode()" class="auth-footer-link" id="resendLink">
                        Reenviar código
                    </a>
                    <span id="timer" style="display: none; color: var(--auth-text-muted); font-size: 0.7rem;"></span>
                </p>
                <p class="auth-footer-text" style="margin-top: 0.5rem;">
                    <a href="/Auth/Login" class="auth-footer-link">← Volver al inicio de sesión</a>
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        // Auto-focus en el campo OTP y formato automático
        const otpInput = document.getElementById('otpCode');
        if (otpInput) {
            otpInput.focus();
            
            // Permitir solo números
            otpInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 6);
            });
            
            // Auto-enviar cuando se complete el código
            otpInput.addEventListener('input', function() {
                if (this.value.length === 6) {
                    document.getElementById('otpForm')?.submit();
                }
            });
        }
        
        // Animación de carga al enviar
        document.getElementById('otpForm')?.addEventListener('submit', function(e) {
            const submitBtn = document.getElementById('submitBtn');
            if (submitBtn && !submitBtn.classList.contains('auth-btn-loading')) {
                submitBtn.classList.add('auth-btn-loading');
                submitBtn.querySelector('span').textContent = 'Verificando...';
            }
        });
        
        // Función para reenviar código
        let timerInterval;
        let timeLeft = 60;
        
        function resendCode() {
            const resendLink = document.getElementById('resendLink');
            const timerSpan = document.getElementById('timer');
            const userId = document.querySelector('input[name="IdUsuario"]')?.value;
            
            if (!userId) {
                showMessage('No se pudo reenviar el código', 'error');
                return;
            }
            
            // Deshabilitar link y mostrar timer
            resendLink.style.pointerEvents = 'none';
            resendLink.style.opacity = '0.5';
            timerSpan.style.display = 'inline';
            timeLeft = 60;
            updateTimer();
            
            // Llamada AJAX para reenviar código
            $.ajax({
                url: '/Auth/ReenviarOTP',
                type: 'POST',
                data: { idUsuario: userId },
                success: function(response) {
                    if (response.success) {
                        showMessage('Código reenviado exitosamente', 'success');
                    } else {
                        showMessage(response.message || 'Error al reenviar código', 'error');
                        resetResendLink();
                    }
                },
                error: function() {
                    showMessage('Error de conexión al reenviar código', 'error');
                    resetResendLink();
                }
            });
        }
        
        function updateTimer() {
            const timerSpan = document.getElementById('timer');
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                resetResendLink();
                return;
            }
            
            timerSpan.textContent = ` (${timeLeft}s)`;
            timeLeft--;
            timerInterval = setTimeout(updateTimer, 1000);
        }
        
        function resetResendLink() {
            const resendLink = document.getElementById('resendLink');
            const timerSpan = document.getElementById('timer');
            
            clearTimeout(timerInterval);
            resendLink.style.pointerEvents = 'auto';
            resendLink.style.opacity = '1';
            timerSpan.style.display = 'none';
        }
        
        function showMessage(message, type) {
            // Remover alertas existentes
            const existingAlert = document.querySelector('.auth-alert');
            if (existingAlert) existingAlert.remove();
            
            // Crear nueva alerta
            const alertDiv = document.createElement('div');
            alertDiv.className = `auth-alert auth-alert-${type === 'success' ? 'success' : 'danger'}`;
            alertDiv.textContent = message;
            
            const form = document.getElementById('otpForm');
            form.insertBefore(alertDiv, form.firstChild);
            
            // Auto-ocultar después de 3 segundos
            setTimeout(() => {
                alertDiv.style.opacity = '0';
                setTimeout(() => alertDiv.remove(), 300);
            }, 3000);
        }
        
        // Iniciar timer si existe un código en sesión (para reenvío)
        const resendLink = document.getElementById('resendLink');
        if (resendLink && resendLink.getAttribute('data-can-resend') === 'false') {
            timeLeft = parseInt(resendLink.getAttribute('data-time-left') || '60');
            updateTimer();
            resendLink.style.pointerEvents = 'none';
            resendLink.style.opacity = '0.5';
            document.getElementById('timer').style.display = 'inline';
        }
    </script>
</body>
</html>