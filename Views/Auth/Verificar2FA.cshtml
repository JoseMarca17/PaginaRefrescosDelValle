@model RefrescosDelValle.Models.ViewModels.VerificarOTPViewModel

@{
    ViewData["Title"] = "Verificación";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verificación 2FA — Refrescos del Valle</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="d-flex align-items-center justify-content-center vh-100 bg-light">
<div class="card shadow p-4 text-center" style="width:380px;">
    <h5 class="fw-bold mb-1">Verificación en dos pasos</h5>
    <p class="text-muted small mb-3">Ingresa el código de 6 dígitos que enviamos a tu correo. Expira en 5 minutos.</p>

    <form asp-action="Verificar2FA" method="post">
        <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

        <input type="hidden" asp-for="IdUsuario" />

        <div class="mb-3">
            <input asp-for="Codigo"
                   class="form-control form-control-lg text-center fw-bold"
                   maxlength="6"
                   placeholder="_ _ _ _ _ _"
                   style="letter-spacing:8px;font-size:28px;" />
            <span asp-validation-for="Codigo" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-success w-100">Verificar</button>
        <a asp-action="Login" class="btn btn-link btn-sm mt-2">← Volver al login</a>
    </form>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>