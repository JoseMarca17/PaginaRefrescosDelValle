@model RefrescosDelValle.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // Desconecta el layout global
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso al Mainframe — Refrescos del Valle</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" />
    <style>
        /* El botón de escape táctico */
        .btn-volver {
            position: absolute;
            top: 1.5rem;
            left: 1.5rem;
            color: var(--auth-text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'DM Mono', monospace;
            font-size: 0.85rem;
            transition: all 0.3s ease;
            z-index: 50;
            text-transform: uppercase;
        }
        .btn-volver:hover {
            color: var(--auth-red);
            transform: translateX(-5px);
        }
    </style>
</head>
<body>
    <div class="auth-container">
        
        <a href="/" class="btn-volver">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Volver al inicio
        </a>

        <div class="auth-card">
            <div class="auth-logo">
                <img src="~/assets/img/LogoRefrescosDelValle.png" alt="RV" onerror="this.src='https://via.placeholder.com/80x80?text=RV'"/>
            </div>
            
            <h1 class="auth-title">Autenticación</h1>
            <p class="auth-subtitle">_INGRESO_DE_USUARIO</p>

            @if (TempData["RegistroExitoso"] != null)
            {
                <div class="auth-alert auth-alert-success" style="margin-bottom: 1.5rem;">
                    Cuenta aprovisionada en la Matrix. Ya puedes iniciar sesión.
                </div>
            }

            <form asp-action="Login" method="post" class="auth-form" id="loginForm">
                <div asp-validation-summary="All" class="auth-alert auth-alert-danger" 
                     style="display:@(ViewData.ModelState.ErrorCount > 0 ? "flex" : "none")"></div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Correo / Usuario</label>
                    <div class="input-icon-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        <input asp-for="Email" class="auth-input" placeholder="usuario@refrescosdelvalle.bo" />
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <div class="input-icon-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <input asp-for="Password" type="password" class="auth-input" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <button type="submit" class="auth-btn" id="submitBtn">
                    <span>Desencriptar Acceso</span>
                </button>
            </form>

            <div style="text-align: center; margin-top: 2rem; border-top: 1px solid var(--auth-border); padding-top: 1.5rem;">
                <p class="auth-footer-text">¿No tienes un nodo asignado?</p>
                <a href="/Auth/Registro" class="auth-btn auth-btn-link" style="border: 1px solid var(--auth-red); padding: 0.6rem; display: block; margin-top: 0.5rem; text-decoration: none; color: white;">
                    Crear cuenta de Cliente
                </a>
            </div>
        </div>
    </div>
</body>
</html>