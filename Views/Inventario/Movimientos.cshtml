@model RefrescosDelValle.Models.ViewModels.MovimientosPageViewModel
@{
    ViewData["Title"] = "Movimientos — Módulo Almacén";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
   <link rel="stylesheet" href="~/css/modulos/inventario.css" asp-append-version="true" /> <!--actualizacion aca-->
    <style>
        body { background: var(--dark-900); }
        .page-hero { background:var(--dark-900); padding:3.5rem 2rem 2.5rem; position:relative; overflow:hidden; border-bottom:1px solid var(--dark-700); }
        .hero-grid-bg { position:absolute; inset:0; pointer-events:none; background-image: repeating-linear-gradient(0deg,transparent,transparent 59px,rgba(192,57,43,.04) 59px,rgba(192,57,43,.04) 60px), repeating-linear-gradient(90deg,transparent,transparent 59px,rgba(192,57,43,.04) 59px,rgba(192,57,43,.04) 60px); }
        .hero-glow { position:absolute; width:500px; height:500px; background:radial-gradient(circle,rgba(192,57,43,.1) 0%,transparent 70%); top:-180px; right:-60px; pointer-events:none; }
        .page-hero-inner { max-width:1200px; margin:0 auto; position:relative; z-index:2; display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
        .page-eyebrow { display:inline-flex; align-items:center; gap:.6rem; font-family:var(--font-mono); font-size:.65rem; color:var(--gray-500); letter-spacing:1.5px; margin-bottom:.75rem; }
        .eyebrow-dot { width:6px; height:6px; border-radius:50%; background:var(--red-500); animation:pulse-dot 2s ease infinite; }
        @@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(.75);}}
        .page-title { font-family:var(--font-display); font-size:clamp(2.5rem,5vw,4rem); color:var(--white); letter-spacing:2px; line-height:.95; }
        .page-title span { -webkit-text-stroke:2px var(--red-500); color:transparent; }
        .page-subtitle { font-size:.88rem; color:var(--gray-500); margin-top:.6rem; font-family:var(--font-mono); }
        .page-hero-btns { display:flex; gap:.75rem; }
        .pg-breadcrumb { background:var(--dark-900); border-bottom:1px solid var(--dark-700); }
        .pg-breadcrumb-inner { max-width:1200px; margin:0 auto; padding:.85rem 2rem; display:flex; align-items:center; gap:.4rem; font-size:.7rem; color:var(--gray-600); font-family:var(--font-mono); }
        .pg-breadcrumb-inner a { color:var(--red-500); text-decoration:none; }
        .pg-breadcrumb-inner a:hover { text-decoration:underline; }
        .pg-breadcrumb-inner svg { width:10px; height:10px; stroke:var(--gray-600); fill:none; stroke-width:2.5; }
        .page-body { max-width:1200px; margin:0 auto; padding:2.5rem 2rem 5rem; }
        @@media(max-width:768px){ .page-hero-inner{flex-direction:column;align-items:flex-start;} }
    </style>
}

<!-- Page hero -->
<div class="page-hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>
    <div class="page-hero-inner">
        <div>
            <div class="page-eyebrow"><span class="eyebrow-dot"></span>INVENTARIO · MOVIMIENTOS</div>
            <div class="page-title">HISTORIAL DE <span>MOVIMIENTOS</span></div>
            <div class="page-subtitle">Traslados, recepciones y mermas por fecha y origen</div>
        </div>
        <div class="page-hero-btns">
            <button class="btn-primary" type="button" onclick="filterMov()">
                <svg style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;margin-right:5px" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Exportar
            </button>
        </div>
    </div>
</div>

<!-- Breadcrumb -->
<div class="pg-breadcrumb">
    <div class="pg-breadcrumb-inner">
        <a asp-controller="Inventario" asp-action="IndexInventario">Inventario</a> <!-- cambio aca -->
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Movimientos</span>
    </div>
</div>

<div class="page-body">
    <!-- KPIs -->
    <div class="kpi-row">
    <div class="kpi-card"><div class="kpi-label">Total este mes</div><div class="kpi-value">@Model.TotalMovimientos</div><div class="kpi-sub">movimientos</div></div>
    <div class="kpi-card"><div class="kpi-label">Traslados</div><div class="kpi-value">@Model.TotalTraslados</div><div class="kpi-sub">normales</div></div>
    <div class="kpi-card"><div class="kpi-label">Mermas</div><div class="kpi-value">@Model.TotalMermas</div><div class="kpi-sub">registradas</div></div>
    <div class="kpi-card"><div class="kpi-label">Unidades movidas</div><div class="kpi-value">@Model.TotalUnidadesMovidas.ToString("N0")</div><div class="kpi-sub">este período</div></div>
</div>

    <!-- Filtros -->
    <div class="mov-filters">
        <div class="filter-group">
            <span class="filter-label">Fecha inicio</span>
            <input type="date" class="mov-filter-input" id="fIni" value="2025-03-01"/>
        </div>
        <div class="filter-group">
            <span class="filter-label">Fecha fin</span>
            <input type="date" class="mov-filter-input" id="fFin" value="2025-03-31"/>
        </div>
        <div class="filter-group">
            <span class="filter-label">Origen (ID sucursal)</span>
            <input type="text" class="mov-filter-input" id="fOrigen" placeholder="Ej: ALM-LP-01"/>
        </div>
        <div class="filter-group">
            <span class="filter-label">Destino (ID sucursal)</span>
            <input type="text" class="mov-filter-input" id="fDestino" placeholder="Ej: ALM-SC-02"/>
        </div>
        <div class="filter-group">
            <span class="filter-label">Tipo</span>
            <select class="mov-filter-input" id="fTipo">
                <option value="">Todos</option>
                <option value="normal">Normal</option>
                <option value="merma">Merma</option>
            </select>
        </div>
        <div class="filter-group">
            <span class="filter-label">&nbsp;</span>
            <button class="btn-primary" type="button" onclick="filterMov()" style="width:100%">Filtrar</button>
        </div>
    </div>

    <!-- Tabla -->
    <div class="data-table-wrap">
        <div class="data-table-header">
            <span class="data-table-title">Historial de movimientos</span>
            <span class="data-table-count" id="movCount">— registros</span>
        </div>
        <div style="overflow-x:auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID Mov.</th>
                        <th>F. Envío</th>
                        <th>F. Recepción</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Tipo</th>
                        <th>Transporte</th>
                        <th>Cantidad</th>
                        <th>Descripción</th>
                    </tr>
                </thead>
                <tbody id="movBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    window.addEventListener('scroll',()=>document.getElementById('navbar')
        ?.classList.toggle('scrolled',window.scrollY>10));

    const DATA = @Html.Raw(Json.Serialize(Model.Movimientos));

    function fmt(d){
        if(!d) return '<span style="color:var(--dark-500);font-size:.72rem">—</span>';
        const[y,m,day]=d.split('-');
        return `${day}/${m}/${y}`;
    }

    function renderTable(rows){
        document.getElementById('movBody').innerHTML = rows.length
            ? rows.map(m=>`<tr>
                <td class="id-cell">${m.id}</td>
                <td class="mono-cell">${fmt(m.fechaEnvio)}</td>
                <td class="mono-cell">${fmt(m.fechaRecepcion)}</td>
                <td class="mono-cell">${m.origen}</td>
                <td class="mono-cell">${m.destino}</td>
                <td><span class="mov-type-badge ${m.esMerma?'merma':'normal'}">${m.esMerma?'⚠ Merma':'↔ Normal'}</span></td>
                <td style="font-family:var(--font-display);font-size:1rem;color:var(--white)">
                    ${Number(m.cantidad).toLocaleString()}
                    <span style="font-family:var(--font-mono);font-size:.65rem;color:var(--gray-600)">u.</span>
                </td>
                <td style="font-size:.78rem;color:var(--gray-500);max-width:240px">${m.descripcion||'—'}</td>
              </tr>`).join('')
            : `<tr><td colspan="8"><div class="empty-state">
                <div class="empty-state-icon">🔄</div>
                <div class="empty-state-title">Sin resultados</div>
                <div class="empty-state-sub">Ajusta los filtros</div>
               </div></td></tr>`;
        document.getElementById('movCount').textContent = `${rows.length} registros`;
    }

    function filterMov(){
        const o   = document.getElementById('fOrigen').value.trim().toLowerCase();
        const d   = document.getElementById('fDestino').value.trim().toLowerCase();
        const t   = document.getElementById('fTipo').value;
        const ini = document.getElementById('fIni').value;
        const fin = document.getElementById('fFin').value;

        const f = DATA.filter(m => {
            if(o && !m.origen?.toLowerCase().includes(o))  return false;
            if(d && !m.destino?.toLowerCase().includes(d)) return false;
            if(t === 'normal' && m.esMerma)                return false;
            if(t === 'merma'  && !m.esMerma)               return false;
            if(ini && m.fechaEnvio < ini)                  return false;
            if(fin && m.fechaEnvio > fin)                  return false;
            return true;
        });
        renderTable(f);
    }

    renderTable(DATA);
</script>
}
}
