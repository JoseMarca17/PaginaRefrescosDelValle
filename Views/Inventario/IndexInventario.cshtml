@model RefrescosDelValle.Models.ViewModels.InventarioIndexViewModel
@{
    ViewData["Title"] = "Módulo Inventario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/inventario.css" />
    <style>
        body { background: var(--dark-900); }

        /* ══ HERO ══ */
        .hero-inv {
            background: var(--dark-900);
            min-height: 88vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            padding: 5rem 2rem;
        }
        .hero-grid-bg {
            position: absolute; inset: 0; pointer-events: none;
            background-image:
                repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(192,57,43,0.05) 59px, rgba(192,57,43,0.05) 60px),
                repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(192,57,43,0.05) 59px, rgba(192,57,43,0.05) 60px);
        }
        .hero-glow { position:absolute; width:700px; height:700px; background:radial-gradient(circle,rgba(192,57,43,.12) 0%,transparent 70%); top:-150px; left:-150px; pointer-events:none; }
        .hero-glow-right { position:absolute; width:400px; height:400px; background:radial-gradient(circle,rgba(192,57,43,.07) 0%,transparent 70%); bottom:-100px; right:-60px; pointer-events:none; }
        .hero-inv-inner { max-width:1200px; margin:0 auto; width:100%; position:relative; z-index:2; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
        .hero-left { max-width:580px; }
        .hero-eyebrow { display:inline-flex; align-items:center; gap:.6rem; font-family:var(--font-mono); font-size:.68rem; color:var(--gray-400); letter-spacing:1.5px; margin-bottom:1.5rem; animation:fadeUp .6s ease both; }
        .eyebrow-dot { width:6px; height:6px; border-radius:50%; background:var(--red-500); animation:pulse-dot 2s ease infinite; }
        @@keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(.75);} }
        .hero-inv-title { font-family:var(--font-display); font-size:clamp(3rem,6vw,5.5rem); color:var(--white); line-height:.95; letter-spacing:2px; margin-bottom:1.5rem; animation:fadeUp .65s ease .1s both; }
        .title-stroke { -webkit-text-stroke:2px var(--red-500); color:transparent; }
        .hero-inv-desc { color:var(--gray-400); font-size:1rem; line-height:1.75; max-width:480px; margin-bottom:2.5rem; animation:fadeUp .65s ease .2s both; }
        .hero-numbers { display:flex; align-items:center; animation:fadeUp .65s ease .35s both; margin-top:1rem; }
        .hn-item { display:flex; flex-direction:column; padding:0 1.75rem; }
        .hn-item:first-child { padding-left:0; }
        .hn-val { font-family:var(--font-display); font-size:2rem; color:var(--red-400); line-height:1; }
        .hn-label { font-size:.68rem; color:var(--gray-500); font-family:var(--font-mono); margin-top:.2rem; }
        .hn-sep { width:1px; height:36px; background:var(--dark-600); }
        .module-cards-stack { display:flex; flex-direction:column; gap:1rem; animation:fadeUp .65s ease .25s both; }
        .module-card { background:var(--dark-800); border:1px solid var(--dark-600); border-radius:var(--radius-lg); padding:1.4rem 1.6rem; display:flex; align-items:center; gap:1.25rem; text-decoration:none; position:relative; overflow:hidden; transition:border-color .22s,transform .2s,box-shadow .22s; }
        .module-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; background:var(--red-600); transform:scaleY(0); transform-origin:bottom; transition:transform .22s; }
        .module-card:hover { border-color:var(--red-600); transform:translateX(4px); box-shadow:var(--shadow-red); }
        .module-card:hover::before { transform:scaleY(1); }
        .mc-icon-wrap { width:52px; height:52px; flex-shrink:0; background:rgba(192,57,43,.1); border:1px solid rgba(192,57,43,.2); border-radius:var(--radius-md); display:flex; align-items:center; justify-content:center; font-size:1.4rem; transition:background .2s,border-color .2s; }
        .module-card:hover .mc-icon-wrap { background:rgba(192,57,43,.2); border-color:var(--red-500); }
        .mc-body { flex:1; }
        .mc-title { font-family:var(--font-display); font-size:1.25rem; color:var(--white); letter-spacing:.5px; line-height:1; margin-bottom:.35rem; }
        .mc-desc { font-size:.8rem; color:var(--gray-500); line-height:1.5; }
        .mc-tag { font-family:var(--font-mono); font-size:.6rem; color:var(--red-400); background:rgba(192,57,43,.1); border:1px solid rgba(192,57,43,.2); border-radius:999px; padding:.15rem .55rem; display:inline-block; margin-top:.45rem; }
        .mc-arrow { width:32px; height:32px; flex-shrink:0; background:var(--dark-700); border-radius:50%; display:flex; align-items:center; justify-content:center; transition:background .18s,transform .18s; }
        .mc-arrow svg { width:13px; height:13px; stroke:var(--gray-400); fill:none; stroke-width:2.5; transition:stroke .18s; }
        .module-card:hover .mc-arrow { background:var(--red-600); transform:translateX(2px); }
        .module-card:hover .mc-arrow svg { stroke:var(--white); }

        /* ══ SECCIÓN RESUMEN ══ */
        .inv-overview { background: var(--dark-800); padding:5rem 2rem; }
        .overview-inner { max-width:1200px; margin:0 auto; }
        .section-header-centered { text-align:center; margin-bottom:3rem; }
        .section-tag { font-family:var(--font-mono); font-size:.65rem; color:var(--red-500); letter-spacing:2px; text-transform:uppercase; margin-bottom:.75rem; }
        .section-title { font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); color:var(--white); letter-spacing:1px; margin-bottom:.5rem; }
        .section-subdesc { font-size:.88rem; color:var(--gray-500); }
        .flow-timeline { display:flex; align-items:flex-start; gap:0; flex-wrap:wrap; justify-content:center; margin-top:2.5rem; }
        .flow-step { display:flex; flex-direction:column; align-items:center; text-align:center; max-width:200px; gap:.75rem; }
        .flow-num { width:44px; height:44px; border-radius:50%; background:var(--red-800); border:2px solid var(--red-600); display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-size:1.2rem; color:var(--white); flex-shrink:0; }
        .flow-title { font-family:var(--font-display); font-size:.95rem; color:var(--white); letter-spacing:.5px; }
        .flow-desc { font-size:.78rem; color:var(--gray-500); line-height:1.6; margin-top:.3rem; }
        .flow-connector { flex:1; min-width:40px; height:2px; background:var(--red-800); margin-top:21px; max-width:80px; }

        /* ══ ACCESO RÁPIDO ══ */
        .quick-access { background:var(--dark-900); padding:5rem 2rem; }
        .qa-inner { max-width:1200px; margin:0 auto; }
        .section-tag.light { color:var(--red-400); }
        .section-title.light { color:var(--white); }
        .qa-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:2.5rem; }
        .qa-card { background:var(--dark-800); border:1px solid var(--dark-600); border-radius:var(--radius-xl); padding:2rem; text-decoration:none; display:flex; flex-direction:column; transition:all .22s; position:relative; overflow:hidden; }
        .qa-card:hover { border-color:var(--red-600); transform:translateY(-4px); box-shadow:var(--shadow-red); }
        .qa-icon { font-size:2.2rem; margin-bottom:1rem; }
        .qa-title { font-family:var(--font-display); font-size:1.4rem; color:var(--white); letter-spacing:1px; margin-bottom:.75rem; }
        .qa-desc { font-size:.82rem; color:var(--gray-500); line-height:1.7; flex:1; margin-bottom:1.25rem; }
        .qa-stats { display:flex; flex-wrap:wrap; gap:.5rem; margin-bottom:1.5rem; }
        .qa-stat { font-family:var(--font-mono); font-size:.65rem; color:var(--red-400); background:rgba(192,57,43,.1); border:1px solid rgba(192,57,43,.2); border-radius:999px; padding:.2rem .65rem; }
        .qa-cta { display:inline-flex; align-items:center; gap:.5rem; font-family:var(--font-mono); font-size:.75rem; color:var(--red-400); margin-top:auto; transition:gap .18s; }
        .qa-cta svg { width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:2; }
        .qa-card:hover .qa-cta { gap:.75rem; }

        @@media(max-width:900px){ .hero-inv-inner{grid-template-columns:1fr;} .qa-grid{grid-template-columns:1fr;} }
        @@media(max-width:640px){ .flow-timeline{flex-direction:column;align-items:center;} .flow-connector{width:2px;height:30px;min-width:unset;margin-top:0;} }
    </style>
}

<!-- ══ HERO ══ -->
<section class="hero-inv">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>
    <div class="hero-glow-right"></div>

    <div class="hero-inv-inner">
        <div class="hero-left">
            <div class="hero-eyebrow">
                <span class="eyebrow-dot"></span>
                SISTEMA · MÓDULO ALMACÉN
            </div>
            <h1 class="hero-inv-title">
                GESTIÓN DE<br>
                <span class="title-stroke">INVENTARIO</span>
            </h1>
            <p class="hero-inv-desc">
                Control centralizado de stock, almacenes por departamento y movimientos
                de mercancía a nivel nacional. Todo en tiempo real.
            </p>
            <div class="hero-numbers">
                <div class="hn-item">
                    <span class="hn-val">@Model.TotalUnidades.ToString("N0")</span>
                    <span class="hn-label">UNIDADES</span>
                </div>
                <div class="hn-sep"></div>
                <div class="hn-item">
                    <span class="hn-val">@Model.TotalAlmacenes</span>
                    <span class="hn-label">ALMACENES</span>
                </div>
                <div class="hn-sep"></div>
                <div class="hn-item">
                    <span class="hn-val">@Model.TotalDepartamentos</span>
                    <span class="hn-label">DEPARTAMENTOS</span>
                </div>
            </div>
        </div>

        <div class="module-cards-stack">
            <a asp-controller="Inventario" asp-action="Stock" class="module-card">
                <div class="mc-icon-wrap">📦</div>
                <div class="mc-body">
                    <div class="mc-title">STOCK</div>
                    <div class="mc-desc">Consulta el inventario disponible por departamento y producto.</div>
                    <span class="mc-tag">847K unidades · 38 SKUs · 3 críticos</span>
                </div>
                <div class="mc-arrow"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></div>
            </a>

            <a asp-controller="Inventario" asp-action="Almacenes" class="module-card">
                <div class="mc-icon-wrap">🏭</div>
                <div class="mc-body">
                    <div class="mc-title">ALMACENES</div>
                    <div class="mc-desc">Vista de almacenes por departamento con capacidad y ocupación detallada.</div>
                    <span class="mc-tag">27 almacenes · 73% ocupación media</span>
                </div>
                <div class="mc-arrow"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></div>
            </a>

            <a asp-controller="Inventario" asp-action="Movimientos" class="module-card">
                <div class="mc-icon-wrap">🔄</div>
                <div class="mc-body">
                    <div class="mc-title">MOVIMIENTOS</div>
                    <div class="mc-desc">Historial de traslados, recepciones y mermas con filtros por fecha y origen.</div>
                    <span class="mc-tag">148 movimientos este mes · 17 mermas</span>
                </div>
                <div class="mc-arrow"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></div>
            </a>
        </div>
    </div>
</section>

<!-- ══ FLUJO DE OPERACIÓN ══ -->
<section class="inv-overview">
    <div class="overview-inner">
        <div class="section-header-centered">
            <div class="section-tag">CÓMO FUNCIONA</div>
            <h2 class="section-title">Flujo de inventario</h2>
            <p class="section-subdesc">Desde la producción hasta la distribución, todo queda registrado</p>
        </div>
        <div class="flow-timeline">
            <div class="flow-step">
                <div class="flow-num">1</div>
                <div>
                    <div class="flow-title">Ingreso al almacén</div>
                    <p class="flow-desc">El producto fabricado se registra en el almacén de origen con su lote y cantidad.</p>
                </div>
            </div>
            <div class="flow-connector"></div>
            <div class="flow-step">
                <div class="flow-num">2</div>
                <div>
                    <div class="flow-title">Traslado interdepartamental</div>
                    <p class="flow-desc">Se genera un movimiento con origen, destino, fecha de envío y recepción confirmada.</p>
                </div>
            </div>
            <div class="flow-connector"></div>
            <div class="flow-step">
                <div class="flow-num">3</div>
                <div>
                    <div class="flow-title">Control de mermas</div>
                    <p class="flow-desc">Las pérdidas por rotura, caducidad o accidente se registran como merma con descripción.</p>
                </div>
            </div>
            <div class="flow-connector"></div>
            <div class="flow-step">
                <div class="flow-num">4</div>
                <div>
                    <div class="flow-title">Stock actualizado</div>
                    <p class="flow-desc">El inventario refleja en tiempo real el stock disponible en cada departamento del país.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ ACCESO RÁPIDO ══ -->
<section class="quick-access">
    <div class="qa-inner">
        <div class="section-header-centered">
            <div class="section-tag light">MÓDULOS</div>
            <h2 class="section-title light">Acceso rápido</h2>
            <p class="section-subdesc">Navega directamente a la sección que necesitas</p>
        </div>
        <div class="qa-grid">
            <a asp-controller="Inventario" asp-action="Stock" class="qa-card">
                <div class="qa-icon">📦</div>
                <div class="qa-title">STOCK</div>
                <p class="qa-desc">Consulta el inventario disponible filtrando por departamento —con selección múltiple de los 9 departamentos de Bolivia— y por producto. La tabla muestra unidades en cajas y botellas con estado de alerta.</p>
                <div class="qa-stats">
                    <span class="qa-stat">847K unidades</span>
                    <span class="qa-stat">38 SKUs</span>
                    <span class="qa-stat">3 críticos</span>
                </div>
                <span class="qa-cta">Ir a Stock <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            </a>

            <a asp-controller="Inventario" asp-action="Almacenes" class="qa-card">
                <div class="qa-icon">🏭</div>
                <div class="qa-title">ALMACENES</div>
                <p class="qa-desc">Visualiza los almacenes activos por departamento. Al seleccionar uno, se despliega el desglose de cada almacén con su nombre, tipo y barra de ocupación sobre capacidad total en toneladas.</p>
                <div class="qa-stats">
                    <span class="qa-stat">27 almacenes</span>
                    <span class="qa-stat">1 840 t capacidad</span>
                    <span class="qa-stat">73% ocup. media</span>
                </div>
                <span class="qa-cta">Ir a Almacenes <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            </a>

            <a asp-controller="Inventario" asp-action="Movimientos" class="qa-card">
                <div class="qa-icon">🔄</div>
                <div class="qa-title">MOVIMIENTOS</div>
                <p class="qa-desc">Filtra el historial de movimientos por rango de fecha, origen y destino (ID sucursal) y tipo. Cada registro muestra fecha de envío, recepción, cantidades y si se trata de un traslado normal o una merma.</p>
                <div class="qa-stats">
                    <span class="qa-stat">148 este mes</span>
                    <span class="qa-stat">131 traslados</span>
                    <span class="qa-stat">17 mermas</span>
                </div>
                <span class="qa-cta">Ir a Movimientos <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            </a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    window.addEventListener('scroll', () =>
        document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 10));
</script>
}
