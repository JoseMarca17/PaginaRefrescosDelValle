@using RefrescosDelValle.Models.Entities
@model IEnumerable<RefrescosDelValle.Models.Entities.VwStockAlmacen>

@{
    ViewData["Title"] = "Stock — Módulo Almacén";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Forzamos el tipado para que Visual Studio no se confunda
    var datos = (Model ?? Enumerable.Empty<VwStockAlmacen>()).ToList();

    // Usamos ?. para evitar errores si algo viene nulo
    var totalUnidades = datos.Sum(x => x.CantidadDisponible ?? 0);
    var productosActivos = datos.Select(x => x.ProductoId).Distinct().Count();
    var stockCritico = datos.Count(x => x.BajoMinimo == 1);
}

@section Styles {
    <link rel="stylesheet" href="~/css/modulos/inventario.css" asp-append-version="true" />
    <style>
        body { background: var(--dark-900); }
        .page-hero { background:var(--dark-900); padding:3.5rem 2rem 2.5rem; position:relative; overflow:hidden; border-bottom:1px solid var(--dark-700); }
        .hero-grid-bg { position:absolute; inset:0; pointer-events:none; background-image: repeating-linear-gradient(0deg,transparent,transparent 59px,rgba(192,57,43,.04) 59px,rgba(192,57,43,.04) 60px), repeating-linear-gradient(90deg,transparent,transparent 59px,rgba(192,57,43,.04) 59px,rgba(192,57,43,.04) 60px); }
        .hero-glow { position:absolute; width:500px; height:500px; background:radial-gradient(circle,rgba(192,57,43,.1) 0%,transparent 70%); top:-180px; right:-60px; pointer-events:none; }
        .page-hero-inner { max-width:1200px; margin:0 auto; position:relative; z-index:2; display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
        .page-eyebrow { display:inline-flex; align-items:center; gap:.6rem; font-family:var(--font-mono); font-size:.65rem; color:var(--gray-500); letter-spacing:1.5px; margin-bottom:.75rem; }
        .eyebrow-dot { width:6px; height:6px; border-radius:50%; background:var(--red-500); animation:pulse-dot 2s ease infinite; }
        @@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(.75);}}
        .page-title { font-family:var(--font-display); font-size:clamp(2.5rem,5vw,4rem); color:var(--white); letter-spacing:2px; line-height:.95; }
        .page-title span { -webkit-text-stroke:2px var(--red-500); color:transparent; }
        .page-subtitle { font-size:.88rem; color:var(--gray-500); margin-top:.6rem; font-family:var(--font-mono); }
        .page-hero-btns { display:flex; gap:.75rem; }
        .pg-breadcrumb { background:var(--dark-900); border-bottom:1px solid var(--dark-700); }
        .pg-breadcrumb-inner { max-width:1200px; margin:0 auto; padding:.85rem 2rem; display:flex; align-items:center; gap:.4rem; font-size:.7rem; color:var(--gray-600); font-family:var(--font-mono); }
        .pg-breadcrumb-inner a { color:var(--red-500); text-decoration:none; }
        .pg-breadcrumb-inner a:hover { text-decoration:underline; }
        .pg-breadcrumb-inner svg { width:10px; height:10px; stroke:var(--gray-600); fill:none; stroke-width:2.5; }
        .page-body { max-width:1200px; margin:0 auto; padding:2.5rem 2rem 5rem; }
        
        /* Ajuste para la tabla con datos reales */
        .stock-badge.critical { background: rgba(231, 76, 60, 0.1); color: #e74c3c; border: 1px solid #e74c3c; }
        .stock-badge.ok { background: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid #2ecc71; }
    </style>
}

<div class="page-hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>
    <div class="page-hero-inner">
        <div>
            <div class="page-eyebrow"><span class="eyebrow-dot"></span>INVENTARIO · STOCK</div>
            <div class="page-title">STOCK <span>ACTUAL</span></div>
            <div class="page-subtitle">Inventario disponible por sucursal y producto</div>
        </div>
        <div class="page-hero-btns">
            <button class="btn-secondary" onclick="location.reload()">
                <svg style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;margin-right:5px" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>Actualizar
            </button>
            <button class="btn-primary">
                <svg style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;margin-right:5px" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Exportar
            </button>
        </div>
    </div>
</div>

<div class="pg-breadcrumb">
    <div class="pg-breadcrumb-inner">
        <a asp-controller="Inventario" asp-action="IndexInventario">Inventario</a>
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Stock</span>
    </div>
</div>

<div class="page-body">
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-label">Total unidades</div>
            <div class="kpi-value">@totalUnidades.ToString("N0")</div>
            <div class="kpi-sub">en todos los almacenes</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Productos activos</div>
            <div class="kpi-value">@productosActivos</div>
            <div class="kpi-sub">SKUs detectados</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Stock crítico</div>
            <div class="kpi-value" style="color:var(--red-500)">@stockCritico</div>
            <div class="kpi-sub">por debajo del mínimo</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Última Sincronización</div>
            <div class="kpi-value" style="font-size:1.25rem;margin-top:4px">@DateTime.Now.ToString("HH:mm")</div>
            <div class="kpi-sub">@DateTime.Now.ToString("dd MMM yyyy")</div>
        </div>
    </div>

    <div class="filter-bar">
        <div class="filter-group">
            <span class="filter-label">Buscador Rápido</span>
            <div class="product-search-wrap">
                <svg class="product-search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" class="product-search-input" id="tableSearch" 
                       placeholder="Filtrar por producto o sucursal..." onkeyup="filterTable()">
            </div>
        </div>
    </div>

    <div class="data-table-wrap">
        <div class="data-table-header">
            <span class="data-table-title">Registros en Tiempo Real</span>
            <span class="data-table-count" id="rowCount">@(Model?.Count() ?? 0) registros</span>
        </div>
        <div style="overflow-x:auto">
            <table class="data-table" id="stockTable">
                <thead>
                    <tr>
                        <th>Sucursal / Almacén</th>
                        <th>Producto</th>
                        <th>SKU</th>
                        <th>Stock Actual</th>
                        <th>Mínimo</th>
                        <th>Lote</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody id="stockBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="stock-row">
                                <td>
                                    <strong style="color:var(--white)">@item.NombreSucursal</strong><br />
                                    <small class="text-muted">@item.NombreAlmacen</small>
                                </td>
                                <td>@item.NombreProducto</td>
                                <td class="id-cell">@item.CodigoSku</td>
                                <td class="num-cell fw-bold @(item.BajoMinimo == 1 ? "text-danger" : "")">
                                    @item.CantidadDisponible?.ToString("N2")
                                </td>
                                <td class="num-cell">@item.CantidadMinima?.ToString("N2")</td>
                                <td class="mono-cell">@item.Lote</td>
                                <td>
                                    @if (item.BajoMinimo == 1)
                                    {
                                        <span class="stock-badge critical">STOCK BAJO</span>
                                    }
                                    else
                                    {
                                        <span class="stock-badge ok">DISPONIBLE</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <div class="empty-state-icon">📦</div>
                                    <div class="empty-state-title">Sin datos</div>
                                    <div class="empty-state-sub">No se encontraron registros en la base de datos.</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    // Filtro rápido en pantalla
    function filterTable() {
        const input = document.getElementById("tableSearch") || document.getElementById("prodInput");
        const filter = input.value.toLowerCase();
        const rows = document.querySelectorAll(".stock-row");
        let count = 0;

        rows.forEach(row => {
            const text = row.innerText.toLowerCase();
            if (text.includes(filter)) {
                row.style.display = "";
                count++;
            } else {
                row.style.display = "none";
            }
        });
        document.getElementById('rowCount').textContent = `${count} registros`;
    }

    // El botón de actualizar ahora recarga la página para traer datos frescos de SQL
    function loadTable() {
        location.reload();
    }

    // Manejo de dropdown de departamentos (opcional si quieres mantener la estética)
    function toggleDept(){ document.getElementById('deptDd')?.classList.toggle('open'); }
    
    window.addEventListener('scroll', () => {
        document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 10);
    });
</script>
}