@{
    ViewData["Title"] = "Contacto";
}

@section Styles {
<style>
.page-header {
  background: var(--negro); padding: 8rem 0 4rem; position: relative; overflow: hidden;
}
.page-header-bg {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 80%, rgba(200,40,30,0.1) 0%, transparent 55%);
  pointer-events: none;
}
.page-header-inner {
  max-width: var(--container); margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2;
}
.page-breadcrumb {
  display: flex; align-items: center; gap: 0.5rem;
  font-family: var(--font-mono); font-size: 0.7rem;
  color: rgba(255,255,255,0.3); margin-bottom: 1.25rem;
}
.page-breadcrumb a { color: rgba(255,255,255,0.4); }
.page-breadcrumb a:hover { color: var(--rojo); }
.page-title {
  font-family: var(--font-display); font-size: clamp(2.5rem,5vw,4.5rem);
  color: var(--blanco); font-weight: 900; line-height: 1; margin-bottom: 1rem;
}
.page-title em { color: var(--rojo); font-style: italic; }
.page-subtitle { font-size: 1.05rem; color: rgba(255,255,255,0.5); max-width: 500px; }

/* ── CONTACTO LAYOUT ── */
.contact-section { padding: var(--section-py) 0; background: var(--gris-50); }
.contact-grid {
  display: grid; grid-template-columns: 1fr 1.4fr; gap: 3rem; align-items: start;
}

/* Info */
.contact-info-block { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 2rem; }
.contact-info-item {
  display: flex; align-items: flex-start; gap: 1rem;
  background: var(--blanco); border: 1px solid var(--gris-100);
  border-radius: var(--radius-md); padding: 1.25rem;
  transition: all 0.2s var(--ease);
}
.contact-info-item:hover { border-color: var(--rojo); box-shadow: var(--shadow-sm); }
.contact-info-icon {
  width: 42px; height: 42px; border-radius: var(--radius-sm);
  background: var(--rojo-suave); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.contact-info-icon svg { width: 18px; height: 18px; stroke: var(--rojo); fill: none; stroke-width: 2; }
.contact-info-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--rojo); letter-spacing: 1.5px; text-transform: uppercase; }
.contact-info-val   { font-size: 0.92rem; font-weight: 500; color: var(--negro); margin-top: 0.2rem; }

/* Form */
.contact-form-card {
  background: var(--blanco); border: 1px solid var(--gris-100);
  border-radius: var(--radius-lg); padding: 2.5rem;
  box-shadow: var(--shadow-sm);
}
.form-title {
  font-family: var(--font-display); font-size: 1.6rem; font-weight: 700;
  color: var(--negro); margin-bottom: 0.4rem;
}
.form-subtitle { font-size: 0.85rem; color: var(--gris-400); margin-bottom: 2rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.1rem; }
.form-label { font-size: 0.82rem; font-weight: 600; color: var(--gris-700); }
.form-input, .form-select, .form-textarea {
  font-family: var(--font-body); font-size: 0.9rem;
  padding: 0.75rem 1rem; border-radius: var(--radius-sm);
  border: 1.5px solid var(--gris-200); background: var(--blanco);
  color: var(--negro); transition: all 0.18s; outline: none;
  width: 100%;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: var(--rojo); box-shadow: 0 0 0 3px rgba(200,40,30,0.08);
}
.form-textarea { resize: vertical; min-height: 120px; }
.form-submit {
  width: 100%; font-family: var(--font-body); font-size: 0.95rem; font-weight: 600;
  padding: 1rem; border-radius: var(--radius-sm);
  background: var(--rojo); color: var(--blanco); border: none;
  cursor: pointer; transition: all 0.2s var(--ease);
  margin-top: 0.5rem;
}
.form-submit:hover { background: var(--rojo-oscuro); transform: translateY(-2px); box-shadow: var(--shadow-red); }

/* Mensaje éxito */
.form-success {
  display: none; text-align: center; padding: 2rem;
}
.form-success-icon { font-size: 3rem; margin-bottom: 1rem; }
.form-success-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--verde); }
.form-success-text  { font-size: 0.88rem; color: var(--gris-500); margin-top: 0.5rem; }

/* ── MAPA PLACEHOLDER ── */
.map-section { padding: 0 0 var(--section-py); background: var(--gris-50); }
.map-placeholder {
  border-radius: var(--radius-lg); overflow: hidden;
  border: 1px solid var(--gris-200); height: 340px;
  background: linear-gradient(135deg, var(--gris-100), var(--gris-50));
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 1rem;
}
.map-placeholder-icon { font-size: 3rem; }
.map-placeholder-text { font-family: var(--font-mono); font-size: 0.75rem; color: var(--gris-400); letter-spacing: 1px; }

/* ── Responsive ── */
@@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; }
  .form-row     { grid-template-columns: 1fr; }
}
</style>
}

<!-- Page Header -->
<section class="page-header">
  <div class="page-header-bg"></div>
  <div class="page-header-inner">
    <div class="page-breadcrumb">
      <a href="/">Inicio</a>
      <span>/</span>
      <span>Contacto</span>
    </div>
    <h1 class="page-title">Trabajemos<br/><em>juntos</em></h1>
    <p class="page-subtitle">¿Interesado en nuestros productos o en ser distribuidor autorizado? Escríbenos.</p>
  </div>
</section>

<!-- Contacto -->
<section class="contact-section">
  <div class="container">
    <div class="contact-grid">

      <!-- Info -->
      <div>
        <div class="section-eyebrow">Información de contacto</div>
        <h2 class="section-title" style="font-size:2rem">Estamos en<br/><em>Cochabamba</em></h2>
        <div class="contact-info-block">
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="contact-info-label">Oficina Central</div>
              <div class="contact-info-val">Cochabamba, Bolivia</div>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.88 9.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.81 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 9.91a16 16 0 006.29 6.29l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div>
              <div class="contact-info-label">Teléfono</div>
              <div class="contact-info-val">+591 4 123-4567</div>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="contact-info-label">Correo</div>
              <div class="contact-info-val">contacto@refrescosdelvalle.bo</div>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="contact-info-label">Horario de atención</div>
              <div class="contact-info-val">Lun – Vie · 8:00 – 18:00</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulario -->
      <div class="contact-form-card">
        <div id="formContent">
          <h3 class="form-title">Enviar mensaje</h3>
          <p class="form-subtitle">Responderemos en menos de 24 horas hábiles.</p>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="cNombre">Nombre</label>
              <input type="text" id="cNombre" class="form-input" placeholder="Tu nombre"/>
            </div>
            <div class="form-group">
              <label class="form-label" for="cApellido">Apellido</label>
              <input type="text" id="cApellido" class="form-input" placeholder="Tu apellido"/>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="cEmail">Correo electrónico</label>
            <input type="email" id="cEmail" class="form-input" placeholder="correo@ejemplo.com"/>
          </div>
          <div class="form-group">
            <label class="form-label" for="cAsunto">Asunto</label>
            <select id="cAsunto" class="form-select">
              <option value="">Selecciona un tema</option>
              <option>Información de productos</option>
              <option>Ser distribuidor autorizado</option>
              <option>Pedidos al por mayor</option>
              <option>Prensa y medios</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="cMensaje">Mensaje</label>
            <textarea id="cMensaje" class="form-textarea" placeholder="¿En qué podemos ayudarte?"></textarea>
          </div>
          <button class="form-submit" onclick="enviarFormulario()">Enviar mensaje →</button>
        </div>
        <div class="form-success" id="formSuccess">
          <div class="form-success-icon">✅</div>
          <div class="form-success-title">¡Mensaje enviado!</div>
          <p class="form-success-text">Gracias por contactarnos. Te responderemos pronto.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Mapa -->
<section class="map-section">
  <div class="container">
    <div class="map-placeholder">
      <div class="map-placeholder-icon">📍</div>
      <div class="map-placeholder-text">COCHABAMBA, BOLIVIA — Integra tu API de Google Maps aquí</div>
    </div>
  </div>
</section>

@section Scripts {
<script>
function enviarFormulario() {
  const nombre  = document.getElementById('cNombre').value.trim();
  const email   = document.getElementById('cEmail').value.trim();
  const mensaje = document.getElementById('cMensaje').value.trim();
  if (!nombre || !email || !mensaje) {
    alert('Por favor completa los campos requeridos.');
    return;
  }
  document.getElementById('formContent').style.display = 'none';
  document.getElementById('formSuccess').style.display = 'block';
}
</script>
}
