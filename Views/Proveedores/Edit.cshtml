@model RefrescosDelValle.Models.Entities.Proveedore

@{
    ViewData["Title"] = "Editar Proveedor";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dashboard-header">
    <div class="header-left">
        <a href="/Proveedores" class="back-button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Volver a Proveedores
        </a>
        <div>
            <h1 class="dashboard-title">Editar Proveedor</h1>
            <p class="dashboard-subtitle">Modificar los datos del proveedor</p>
        </div>
    </div>
    <div class="dashboard-header-right">
        <div class="date-badge">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <rect x="3" y="4" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
        </div>
    </div>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProveedorId" />
    <input type="hidden" asp-for="FechaRegistro" />

    <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; backdrop-filter: blur(10px);">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1.5rem; color: #C8281E; font-family: 'DM Mono', monospace; font-size: 0.85rem;"></div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
            <div>
                <label asp-for="RazonSocial" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Razón Social *
                </label>
                <input asp-for="RazonSocial" class="form-control-modern" 
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
                <span asp-validation-for="RazonSocial" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>

            <div>
                <label asp-for="Nit" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    NIT *
                </label>
                <input asp-for="Nit" class="form-control-modern" 
                       style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
                <span asp-validation-for="Nit" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>

            <div>
                <label asp-for="Activo" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Estado
                </label>
                <select asp-for="Activo" class="form-select-modern" style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>

            <div>
                <label style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Fecha Registro
                </label>
                <input class="form-control-modern" value="@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")" readonly disabled
                       style="width: 100%; background: rgba(0,0,0,0.3); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-muted); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
            </div>

            <div style="grid-column: span 2;">
                <label asp-for="Observaciones" style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                    Observaciones
                </label>
                <textarea asp-for="Observaciones" rows="3" 
                          style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; resize: vertical;"></textarea>
                <span asp-validation-for="Observaciones" style="color: #C8281E; font-size: 0.75rem; font-family: 'DM Mono', monospace;"></span>
            </div>
        </div>
    </div>

    <div style="display: flex; gap: 1rem;">
        <button type="submit" style="background: #C8281E; color: white; padding: 0.8rem 2rem; border-radius: 8px; border: 1px solid #ff4d4d; font-family: 'DM Mono', monospace; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 0.5rem;">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                <polyline points="17 21 17 13 7 13 7 21"/>
                <polyline points="7 3 7 8 15 8"/>
            </svg>
            Guardar Cambios
        </button>
        <a href="/Proveedores" style="background: transparent; color: var(--text-secondary); padding: 0.8rem 2rem; border-radius: 8px; border: 1px solid var(--border-color); text-decoration: none; font-family: 'DM Mono', monospace; font-size: 0.85rem; text-transform: uppercase; transition: all 0.3s; display: flex; align-items: center; gap: 0.5rem;">
            Cancelar
        </a>
    </div>
</form>

<style>
    button[type="submit"]:hover {
        background: #a02018 !important;
        transform: translateY(-2px);
        box-shadow: 0 0 20px rgba(200, 40, 30, 0.5);
    }
    
    .form-control-modern:focus, .form-select-modern:focus {
        outline: none;
        border-color: #C8281E;
        box-shadow: 0 0 10px rgba(200, 40, 30, 0.3);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}