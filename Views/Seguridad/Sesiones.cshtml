@{
    ViewData["Title"] = "Monitor de Sesiones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .page-wrapper { max-width: 1200px; margin: 0 auto; padding: 6rem 2rem; position: relative; z-index: 2; }
        .page-header { margin-bottom: 2.5rem; border-left: 4px solid var(--red-600); padding-left: 1.5rem; }
        .page-title { font-family: var(--font-display); font-size: 2.2rem; color: var(--white); margin-bottom: 0.5rem; }
        .page-desc { color: var(--gray-400); font-size: 0.95rem; }
        
        .terminal-box { background: #050202; border: 1px solid var(--dark-600); border-radius: 8px; overflow: hidden; font-family: var(--font-mono); box-shadow: var(--shadow-lg); }
        .term-head { background: var(--dark-800); padding: 0.8rem 1.2rem; display: flex; gap: 8px; align-items: center; border-bottom: 1px solid var(--dark-700); }
        .term-dot { width: 12px; height: 12px; border-radius: 50%; }
        .term-dot.r { background: #ff5f56; } .term-dot.y { background: #ffbd2e; } .term-dot.g { background: #27c93f; }
        .term-cmd { margin-left: 10px; color: var(--gray-400); font-size: 0.85rem; }
        
        .term-table { width: 100%; border-collapse: collapse; color: #00ff41; font-size: 0.85rem; }
        .term-table th { text-align: left; padding: 1.2rem; background: #0a0a0a; color: var(--red-500); text-transform: uppercase; border-bottom: 1px solid var(--dark-700); }
        .term-table td { padding: 1.2rem; border-bottom: 1px dashed var(--dark-700); }
        .status-active { color: #00ff41; text-shadow: 0 0 5px rgba(0,255,65,0.4); font-weight: bold; }
    </style>
}

<div class="page-wrapper">
    <div class="page-header">
        <h1 class="page-title">Sesiones Activas</h1>
        <p class="page-desc">Monitoreo de conexiones a la base de datos.</p>
    </div>

    <div class="terminal-box">
        <div class="term-head">
            <span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span>
            <span class="term-cmd">root@soc:~# tail -f /var/log/auth.log</span>
        </div>
        <div class="term-body">
            <table class="term-table">
                <thead>
                    <tr>
                        <th>ID_SESIÓN</th>
                        <th>USUARIO</th>
                        <th>DIRECCIÓN_IP</th>
                        <th>DISPOSITIVO</th>
                        <th>ESTADO</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>#8842</td>
                        <td>SysAdmin</td>
                        <td>192.168.10.45</td>
                        <td>Linux / Firefox</td>
                        <td><span class="status-active">[ ACTIVA ]</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>  