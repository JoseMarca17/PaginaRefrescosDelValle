@model IEnumerable<RefrescosDelValle.Models.ViewModels.UsuarioItemViewModel>

@{
    ViewData["Title"] = "Directorio de Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* Mantenemos tus estilos originales */
        .page-wrapper { max-width: 1200px; margin: 0 auto; padding: 6rem 2rem; position: relative; z-index: 2; }
        .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; border-bottom: 1px solid var(--dark-700); padding-bottom: 1.5rem; }
        .page-title { font-family: var(--font-display); font-size: 2.2rem; color: var(--white); border-left: 4px solid var(--red-600); padding-left: 1rem; }
        .btn-red { background: var(--red-600); color: var(--white); padding: 0.6rem 1.5rem; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: 0.2s; }
        .btn-red:hover { background: var(--red-500); box-shadow: 0 4px 15px rgba(200,40,30,0.3); }
        .users-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
        .user-card { background: var(--dark-800); border: 1px solid var(--dark-600); border-radius: var(--radius-lg); padding: 1.5rem; transition: 0.2s; }
        .user-card:hover { border-color: var(--red-600); transform: translateY(-3px); }
        .uc-head { display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; }
        .uc-avatar { width: 50px; height: 50px; background: var(--red-700); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 1.2rem; font-weight: bold; color: var(--white); }
        .uc-name { color: var(--white); font-size: 1.1rem; margin-bottom: 0.2rem; }
        .uc-email { color: var(--gray-500); font-size: 0.8rem; font-family: var(--font-mono); }
        .uc-body { display: flex; flex-direction: column; gap: 0.5rem; border-top: 1px dashed var(--dark-600); padding-top: 1rem; }
        .uc-row { display: flex; justify-content: space-between; font-size: 0.85rem; }
        .uc-label { color: var(--gray-400); }
        .uc-val { color: var(--white); font-weight: 500; text-align: right; }
        .uc-val.red { color: var(--red-400); }

        /* Botones de acción */
        .uc-actions { display: flex; gap: 0.5rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--dark-600); }
        .action-btn { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 0.3rem;
            padding: 0.4rem 0; border-radius: 6px; font-size: 0.75rem; font-weight: 600;
            text-decoration: none; border: none; cursor: pointer; transition: all 0.2s; }
        .btn-edit { background: rgba(241,196,15,0.1); color: #f1c40f; border: 1px solid rgba(241,196,15,0.25); }
        .btn-edit:hover { background: rgba(241,196,15,0.2); color: #f1c40f; }
        .btn-toggle-off { background: rgba(231,76,60,0.1); color: #e74c3c; border: 1px solid rgba(231,76,60,0.25); }
        .btn-toggle-off:hover { background: rgba(231,76,60,0.2); color: #e74c3c; }
        .btn-toggle-on { background: rgba(46,204,113,0.1); color: #2ecc71; border: 1px solid rgba(46,204,113,0.25); }
        .btn-toggle-on:hover { background: rgba(46,204,113,0.2); color: #2ecc71; }
    </style>
}

<div class="page-wrapper">
    <div class="header-flex">
        <h1 class="page-title">Directorio de Identidades</h1>
        <a asp-action="RegistrarPersonal" class="btn-red">+ Nuevo Registro</a>
    </div>

    <div class="users-grid">
        @foreach (var user in Model)
        {
            <div class="user-card">
                <div class="uc-head">
                    <div class="uc-avatar">@user.Iniciales</div>
                    <div>
                        <div class="uc-name">@user.NombreCompleto</div>
                        <div class="uc-email">@user.Email</div>
                    </div>
                </div>
                <div class="uc-body">
                    <div class="uc-row">
                        <span class="uc-label">Roles:</span> 
                        <span class="uc-val red">@user.Roles</span>
                    </div>
                    <div class="uc-row">
                        <span class="uc-label">Nodo Base:</span> 
                        <span class="uc-val">@user.Sucursal</span>
                    </div>
                    <div class="uc-row">
                        <span class="uc-label">Estado:</span> 
                        <span class="uc-val" style="color: @(user.Activo ? "#27c93f" : "#ff4d4d");">
                            @(user.Activo ? "Activo" : "Suspendido")
                        </span>
                    </div>
                </div>

                <div class="uc-actions">
                    <a asp-controller="Seguridad" asp-action="EditarUsuario"
                       asp-route-id="@user.UsuarioID" class="action-btn btn-edit">
                        ✏ Editar
                    </a>
                    <form asp-controller="Seguridad" asp-action="ToggleUsuario"
                          asp-route-id="@user.UsuarioID" method="post" style="flex:1; display:flex;"
                          onsubmit="return confirm('@(user.Activo ? "¿Desactivar a " : "¿Reactivar a ")@user.NombreCompleto?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="action-btn @(user.Activo ? "btn-toggle-off" : "btn-toggle-on")" style="width:100%;">
                            @(user.Activo ? "🔒 Desactivar" : "🔓 Reactivar")
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
