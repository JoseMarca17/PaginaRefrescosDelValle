@{
    ViewData["Title"] = "Gestión de Logística";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dashboard-header">
    <div class="header-left">
        <a href="@Url.Action("Comercial", "Dashboard")" class="back-button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Volver al Panel
        </a>
        <div>
            <h1 class="dashboard-title">Logística y Despachos</h1>
            <p class="dashboard-subtitle">Control de flota y rutas de entrega</p>
        </div>
    </div>
</div>

<div class="container-fluid mt-4">
    <!-- Tarjetas de resumen -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">En Ruta</h6>
                            <h3 class="mb-0 text-primary">8</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0d6efd" stroke-width="2">
                                <circle cx="12" cy="12" r="10" stroke="currentColor"/>
                                <path d="M12 8v4l3 3" stroke="currentColor"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Entregados Hoy</h6>
                            <h3 class="mb-0 text-success">15</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#198754" stroke-width="2">
                                <path d="M20 7L9 18L4 13" stroke="currentColor" stroke-linecap="round"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Vehículos Activos</h6>
                            <h3 class="mb-0 text-info">6</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0dcaf0" stroke-width="2">
                                <rect x="2" y="9" width="20" height="10" rx="2" stroke="currentColor"/>
                                <circle cx="7" cy="17" r="2" stroke="currentColor"/>
                                <circle cx="17" cy="17" r="2" stroke="currentColor"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Retrasos</h6>
                            <h3 class="mb-0 text-danger">2</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="2">
                                <circle cx="12" cy="12" r="10" stroke="currentColor"/>
                                <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor"/>
                                <line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Despachos -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-0 pt-4 pb-0">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Despachos Activos</h5>
                <button class="btn btn-primary btn-sm">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                        <path d="M12 5v14M5 12h14" stroke="currentColor"/>
                    </svg>
                    Nuevo Despacho
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID Despacho</th>
                            <th>Cliente</th>
                            <th>Destino</th>
                            <th>Vehículo</th>
                            <th>Fecha Estimada</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-2">
                                    <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor"/>
                                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke="currentColor"/>
                                </svg>
                                <p class="mb-0">No hay despachos activos</p>
                                <small class="text-muted">Los datos se cargarán desde las tablas Despachos y Vehiculos</small>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Tabla de Vehículos -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pt-4 pb-0">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Flota de Vehículos</h5>
                <button class="btn btn-outline-primary btn-sm">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                        <path d="M12 5v14M5 12h14" stroke="currentColor"/>
                    </svg>
                    Agregar Vehículo
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Patente</th>
                            <th>Modelo</th>
                            <th>Capacidad (kg)</th>
                            <th>Conductor</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-2">
                                    <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor"/>
                                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke="currentColor"/>
                                </svg>
                                <p class="mb-0">No hay vehículos registrados</p>
                                <small class="text-muted">Los datos se cargarán desde la tabla Vehiculos</small>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>