@{
    ViewData["Title"] = "Módulo de Compras";
}

<div class="container mt-4">
    <h1 class="mb-4">Módulo de Compras</h1>
    
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Proveedores</h5>
                    <p class="card-text">Administrar catálogo de proveedores</p>
                    <a asp-action="Proveedores" class="btn btn-light">Administrar</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Órdenes de Compra</h5>
                    <p class="card-text">Gestionar órdenes de compra a proveedores</p>
                    <a asp-action="OrdenesCompra" class="btn btn-light">Administrar</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-info h-100">
                <div class="card-body">
                    <h5 class="card-title">Recepciones</h5>
                    <p class="card-text">Registrar recepción de mercadería</p>
                    <a asp-action="Recepciones" class="btn btn-light">Administrar</a>
                </div>
            </div>
        </div>
    </div>
</div>