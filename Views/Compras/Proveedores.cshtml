@model IEnumerable<RefrescosDelValle.Models.Entities.Proveedore>

@{
    ViewData["Title"] = "Proveedores";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Proveedores</h1>
        <a asp-action="CrearProveedor" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nuevo Proveedor
        </a>
    </div>
    
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Proveedores" method="get" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="searchString" class="form-control" 
                           placeholder="Buscar por Razón Social o NIT..." 
                           value="@ViewBag.CurrentFilter" />
                </div>
                <div class="col-md-3">
                    <select name="activo" class="form-select">
                        <option value="">Todos</option>
                        <option value="true" selected="@(ViewBag.CurrentActivo == true)">Activos</option>
                        <option value="false" selected="@(ViewBag.CurrentActivo == false)">Inactivos</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">Buscar</button>
                    <a asp-action="Proveedores" class="btn btn-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Razón Social</th>
                    <th>NIT</th>
                    <th>Estado</th>
                    <th>Fecha Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProveedorId</td>
                        <td>@item.RazonSocial</td>
                        <td>@item.Nit</td>
                        <td>
                            @if (item.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>
                        <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="ProveedorDetails" asp-route-id="@item.ProveedorId" class="btn btn-sm btn-info">Detalles</a>
                            <a asp-action="EditarProveedor" asp-route-id="@item.ProveedorId" class="btn btn-sm btn-warning">Editar</a>
                            <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.ProveedorId, '@item.RazonSocial')">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="EliminarProveedor" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id, nombre) {
            if (confirm(`¿Está seguro de eliminar el proveedor "${nombre}"?`)) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}