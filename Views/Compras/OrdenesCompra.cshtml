@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Órdenes de Compra";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Órdenes de Compra</h1>
        <a asp-action="CrearOrdenCompra" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nueva Orden
        </a>
    </div>
    
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="OrdenesCompra" method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="searchString" class="form-control" 
                           placeholder="Número o Proveedor..." value="@ViewBag.CurrentFilter" />
                </div>
                <div class="col-md-3">
                    <select name="proveedorId" class="form-select" asp-items="ViewBag.Proveedores">
                        <option value="">Todos los proveedores</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="date" name="fechaDesde" class="form-control" value="@ViewBag.FechaDesde" />
                </div>
                <div class="col-md-2">
                    <input type="date" name="fechaHasta" class="form-control" value="@ViewBag.FechaHasta" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">Buscar</button>
                    <a asp-action="OrdenesCompra" class="btn btn-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>N° Orden</th>
                    <th>Proveedor</th>
                    <th>Fecha Emisión</th>
                    <th>Fecha Entrega</th>
                    <th>Monto Total</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NumeroOrden</td>
                        <td>@item.ProveedorNombre</td>
                        <td>@item.FechaEmision.ToString("dd/MM/yyyy")</td>
                        <td>@(item.FechaEntregaEsp?.ToString("dd/MM/yyyy") ?? "Pendiente")</td>
                        <td>@item.MontoTotal.ToString("C")</td>
                        <td>
                            @if (item.CantidadRecepciones == 0)
                            {
                                <span class="badge bg-warning">Pendiente</span>
                            }
                            else if (item.TotalRecibido >= item.MontoTotal)
                            {
                                <span class="badge bg-success">Completada</span>
                            }
                            else
                            {
                                <span class="badge bg-info">Parcial</span>
                            }
                        </td>
                        <td>
                            <a asp-action="OrdenCompraDetails" asp-route-id="@item.OrdenCompraId" class="btn btn-sm btn-info">Detalles</a>
                            <a asp-action="EditarOrdenCompra" asp-route-id="@item.OrdenCompraId" class="btn btn-sm btn-warning">Editar</a>
                            <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.OrdenCompraId, '@item.NumeroOrden')">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="EliminarOrdenCompra" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id, numero) {
            if (confirm(`¿Está seguro de eliminar la orden "${numero}"?`)) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}