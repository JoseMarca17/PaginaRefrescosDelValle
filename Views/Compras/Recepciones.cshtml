@model IEnumerable<RefrescosDelValle.Models.Entities.RecepcionMercaderium>

@{
    ViewData["Title"] = "Recepciones";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Recepciones de Mercadería</h1>
        <a asp-action="CrearRecepcion" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nueva Recepción
        </a>
    </div>
    
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Recepciones" method="get" class="row g-3">
                <div class="col-md-4">
                    <select name="ordenCompraId" class="form-select" asp-items="ViewBag.OrdenesCompra">
                        <option value="">Todas las órdenes</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" name="fechaDesde" class="form-control" value="@ViewBag.FechaDesde" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="fechaHasta" class="form-control" value="@ViewBag.FechaHasta" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">Buscar</button>
                    <a asp-action="Recepciones" class="btn btn-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>N° Orden</th>
                    <th>Producto</th>
                    <th>Lote</th>
                    <th>Cantidad</th>
                                        <th>Almacén</th>
                    <th>Fecha Recepción</th>
                    <th>Usuario</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.RecepcionId</td>
                        <td>@item.OrdenCompra?.NumeroOrden</td>
                        <td>@item.Inventario?.Producto?.NombreProducto</td>
                        <td>@item.Inventario?.Lote</td>
                        <td>@item.CantidadRecibida.ToString("N2")</td>
                        <td>@item.Almacen?.NombreAlmacen</td>
                        <td>@item.FechaRecepcion.ToString("dd/MM/yyyy")</td>
                        <td>@item.Usuario?.NombreUsuario</td>
                        <td>
                            <a asp-action="RecepcionDetails" asp-route-id="@item.RecepcionId" class="btn btn-sm btn-info">Detalles</a>
                            <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.RecepcionId)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="EliminarRecepcion" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('¿Está seguro de eliminar esta recepción? Esta acción también eliminará el inventario asociado.')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}