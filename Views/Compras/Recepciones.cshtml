@model IEnumerable<RefrescosDelValle.Models.Entities.RecepcionMercaderium>

@{
    ViewData["Title"] = "Recepciones";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dashboard-header">
    <div class="header-left">
        <a href="/Dashboard" class="back-button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Volver al Dashboard
        </a>
        <div>
            <h1 class="dashboard-title">Recepciones de Mercadería</h1>
            <p class="dashboard-subtitle">Gestión de recepciones y control de inventario</p>
        </div>
    </div>
    <div class="dashboard-header-right" style="display: flex; align-items: center; gap: 1rem;">
        <a href="/Compras/CrearRecepcion" style="background: #C8281E; color: white; padding: 0.6rem 1.2rem; border-radius: 8px; text-decoration: none; font-family: 'DM Mono', monospace; font-weight: bold; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; transition: all 0.3s; text-transform: uppercase; border: 1px solid #ff4d4d; box-shadow: 0 0 10px rgba(200, 40, 30, 0.3);">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nueva Recepción
        </a>
        <div class="date-badge">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <rect x="3" y="4" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
        </div>
    </div>
</div>

<div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; backdrop-filter: blur(10px);">
    <form asp-action="Recepciones" method="get" style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
        <div style="flex: 2; min-width: 200px;">
            <label style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                Orden de Compra
            </label>
            <select name="ordenCompraId" asp-items="ViewBag.OrdenesCompra" 
                    style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;">
                <option value="">Todas las órdenes</option>
            </select>
        </div>
        
        <div style="flex: 1; min-width: 150px;">
            <label style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                Desde
            </label>
            <input type="date" name="fechaDesde" value="@ViewBag.FechaDesde" 
                   style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
        </div>
        
        <div style="flex: 1; min-width: 150px;">
            <label style="display: block; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">
                Hasta
            </label>
            <input type="date" name="fechaHasta" value="@ViewBag.FechaHasta" 
                   style="width: 100%; background: var(--input-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.7rem 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;" />
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <button type="submit" style="background: #C8281E; color: white; padding: 0.7rem 1.5rem; border-radius: 8px; border: 1px solid #ff4d4d; font-family: 'DM Mono', monospace; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; cursor: pointer; transition: all 0.3s;">
                <svg viewBox="0 0 24 24" width="14" height="14" style="display: inline; margin-right: 6px; vertical-align: middle;">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" fill="none" stroke-width="2"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2"/>
                </svg>
                Buscar
            </button>
            <a href="/Compras/Recepciones" style="background: transparent; color: var(--text-secondary); padding: 0.7rem 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); text-decoration: none; font-family: 'DM Mono', monospace; font-size: 0.85rem; text-transform: uppercase; transition: all 0.3s;">
                Limpiar
            </a>
        </div>
    </form>
</div>

<div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; backdrop-filter: blur(10px);">
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: rgba(200, 40, 30, 0.1); border-bottom: 2px solid #C8281E;">
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">ID</th>
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">N° Orden</th>
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Producto</th>
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Lote</th>
                    <th style="padding: 1rem; text-align: right; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Cantidad</th>
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Almacén</th>
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Fecha Recepción</th>
                    <th style="padding: 1rem; text-align: left; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Usuario</th>
                    <th style="padding: 1rem; text-align: center; color: var(--text-primary); font-family: 'DM Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.3s;" 
                        onmouseover="this.style.background='var(--input-bg)'" 
                        onmouseout="this.style.background='transparent'">
                        <td style="padding: 1rem; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.85rem;">
                            #@item.RecepcionId.ToString("D6")
                        </td>
                        <td style="padding: 1rem; color: #00ffff; font-family: 'DM Mono', monospace; font-weight: bold;">
                            @item.OrdenCompra?.NumeroOrden
                        </td>
                        <td style="padding: 1rem; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; font-weight: 500;">
                            @item.Inventario?.Producto?.NombreProducto
                        </td>
                        <td style="padding: 1rem; color: #00ff88; font-family: 'DM Mono', monospace;">
                            @item.Inventario?.Lote
                        </td>
                        <td style="padding: 1rem; text-align: right; color: #00ff88; font-family: 'DM Mono', monospace; font-weight: bold;">
                            @item.CantidadRecibida.ToString("N2")
                        </td>
                        <td style="padding: 1rem; color: var(--text-secondary); font-family: 'Space Grotesk', sans-serif;">
                            @item.Almacen?.NombreAlmacen
                        </td>
                        <td style="padding: 1rem; color: var(--text-secondary); font-family: 'DM Mono', monospace; font-size: 0.85rem;">
                            @item.FechaRecepcion.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td style="padding: 1rem; color: var(--text-secondary); font-family: 'Space Grotesk', sans-serif;">
                            @item.Usuario?.NombreUsuario
                        </td>
                        <td style="padding: 1rem;">
                            <div style="display: flex; gap: 0.5rem; justify-content: center;">
                                <a href="/Compras/RecepcionDetails/@item.RecepcionId" style="background: rgba(0, 255, 255, 0.1); color: #00ffff; padding: 0.4rem 0.8rem; border-radius: 6px; text-decoration: none; font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; border: 1px solid rgba(0, 255, 255, 0.3); transition: all 0.3s;">
                                    <svg viewBox="0 0 24 24" width="12" height="12" style="display: inline; margin-right: 4px; vertical-align: middle;">
                                        <circle cx="12" cy="12" r="3" stroke="currentColor" fill="none"/>
                                        <path d="M22 12c-2.667 4.667-6 7-10 7s-7.333-2.333-10-7c2.667-4.667 6-7 10-7s7.333 2.333 10 7z" stroke="currentColor" fill="none"/>
                                    </svg>
                                    Detalles
                                </a>
                                <button type="button" onclick="confirmDelete(@item.RecepcionId)" 
                                        style="background: rgba(200, 40, 30, 0.1); color: #C8281E; padding: 0.4rem 0.8rem; border-radius: 6px; border: 1px solid rgba(200, 40, 30, 0.3); font-family: 'DM Mono', monospace; font-size: 0.75rem; text-transform: uppercase; cursor: pointer; transition: all 0.3s;">
                                    <svg viewBox="0 0 24 24" width="12" height="12" style="display: inline; margin-right: 4px; vertical-align: middle;">
                                        <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" stroke="currentColor" fill="none"/>
                                    </svg>
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" style="padding: 3rem; text-align: center; color: var(--text-muted); font-family: 'DM Mono', monospace;">
                            <svg viewBox="0 0 24 24" width="48" height="48" style="margin-bottom: 1rem; opacity: 0.3;">
                                <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" fill="none"/>
                                <path d="M8 7v10M16 7v10M7 12h10" stroke="currentColor"/>
                            </svg>
                            <br />
                            No se encontraron recepciones
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" asp-action="EliminarRecepcion" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

<style>
    button[type="submit"]:hover {
        background: #a02018 !important;
        transform: translateY(-2px);
        box-shadow: 0 0 20px rgba(200, 40, 30, 0.5);
    }
    
    a[href="/Compras/Recepciones"]:hover {
        background: var(--input-bg) !important;
        color: var(--text-primary) !important;
    }
    
    td a:hover {
        filter: brightness(1.2);
        transform: translateY(-1px);
    }
    
    td button:hover {
        background: rgba(200, 40, 30, 0.2) !important;
        transform: translateY(-1px);
    }
    
    .dashboard-header a[href="/Compras/CrearRecepcion"]:hover {
        background: #a02018 !important;
        transform: translateY(-2px);
        box-shadow: 0 0 20px rgba(200, 40, 30, 0.5);
    }
</style>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('¿Está seguro de eliminar esta recepción? Esta acción también eliminará el inventario asociado.')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}