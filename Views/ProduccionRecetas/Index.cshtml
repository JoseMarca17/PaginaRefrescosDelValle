@* 
    Vista: Views/ProduccionRecetas/Index.cshtml
    Módulo: Producción y Recetas - Refrescos Del Valle
*@

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@{
    ViewData["Title"] = "Producción y Recetas";
    <link rel="stylesheet" href="~/css/modulos/produccionRecetas.css" />
}



<div class="container">
    <!-- Título de Sección -->
    <div class="section-title">
        <h1>Control de Producción</h1>
        <p>Gestión de recetas y seguimiento de órdenes de producción</p>
    </div>

    <!-- Dashboard de Resumen -->
    <div class="dashboard-grid">
        <!-- Card 1: Total Recetas Activas -->
        <div class="card anim-up">
            <div class="card-icon">📋</div>
            <div class="card-stats">
                <span class="stats-number" id="totalRecetasActivas">24</span>
                <span class="stats-label">Recetas Activas</span>
            </div>
            <div class="card-footer">
                <span class="pill-verde">+3 este mes</span>
            </div>
        </div>

        <!-- Card 2: Órdenes en Curso -->
        <div class="card anim-up" style="animation-delay: 0.1s;">
            <div class="card-icon">⚙️</div>
            <div class="card-stats">
                <span class="stats-number" id="ordenesEnCurso">8</span>
                <span class="stats-label">Órdenes Activas</span>
            </div>
            <div class="card-footer">
                <span class="pill-amarillo">2 en producción</span>
            </div>
        </div>

        <!-- Card 3: Eficiencia -->
        <div class="card anim-up" style="animation-delay: 0.2s;">
            <div class="card-icon">📊</div>
            <div class="card-stats">
                <span class="stats-number" id="eficienciaProduccion">87.5</span>
                <span class="stats-label">% Eficiencia Global</span>
            </div>
            <div class="card-footer">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 87.5%"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gestión de Recetas -->
    <div class="card">
        <div class="card-header">
            <h2>📋 Catálogo de Recetas</h2>
            <button class="btn-rojo" id="btnNuevaReceta">
                <span>+</span> Nueva Receta
            </button>
        </div>
        <div class="table-responsive">
            <table class="table-elegante">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Versión</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Confidencial</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaRecetasBody">
                    <tr>
                        <td class="producto-nombre">Refresco Cola</td>
                        <td>2.1.0</td>
                        <td>Estándar</td>
                        <td><span class="pill-verde">Activa</span></td>
                        <td><span class="pill-rojo">Sí</span></td>
                        <td class="acciones">
                            <button class="btn-icon btn-editar" data-id="1" title="Editar">✏️</button>
                            <button class="btn-icon btn-ver" data-id="1" title="Ver Detalle">👁️</button>
                        </td>
                    </tr>
                    <tr>
                        <td class="producto-nombre">Naranja Sabor Intenso</td>
                        <td>1.5.2</td>
                        <td>Premium</td>
                        <td><span class="pill-verde">Activa</span></td>
                        <td><span class="pill-rojo">Sí</span></td>
                        <td class="acciones">
                            <button class="btn-icon btn-editar" data-id="2" title="Editar">✏️</button>
                            <button class="btn-icon btn-ver" data-id="2" title="Ver Detalle">👁️</button>
                        </td>
                    </tr>
                    <tr>
                        <td class="producto-nombre">Lima Limón Zero</td>
                        <td>3.0.0</td>
                        <td>Light</td>
                        <td><span class="pill-verde">Activa</span></td>
                        <td><span class="pill-verde">No</span></td>
                        <td class="acciones">
                            <button class="btn-icon btn-editar" data-id="3" title="Editar">✏️</button>
                            <button class="btn-icon btn-ver" data-id="3" title="Ver Detalle">👁️</button>
                        </td>
                    </tr>
                    <tr>
                        <td class="producto-nombre">Manzana Verde</td>
                        <td>1.2.0</td>
                        <td>Estándar</td>
                        <td><span class="pill-gris">Inactiva</span></td>
                        <td><span class="pill-verde">No</span></td>
                        <td class="acciones">
                            <button class="btn-icon btn-editar" data-id="4" title="Editar">✏️</button>
                            <button class="btn-icon btn-ver" data-id="4" title="Ver Detalle">👁️</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Órdenes de Producción -->
    <div class="card">
        <div class="card-header">
            <h2>🚀 Órdenes en Progreso</h2>
            <button class="btn-verde" id="btnNuevaOrden">+ Nueva Orden</button>
        </div>
        <div class="ordenes-grid" id="ordenesProduccionGrid">
            <div class="orden-card">
                <div class="orden-header">
                    <span class="orden-numero">#ORD-2401-001</span>
                    <span class="pill-verde">En Proceso</span>
                </div>
                <div class="orden-body">
                    <div class="orden-info">
                        <span class="info-label">Línea</span>
                        <span class="info-value">Línea 1 - Envasado</span>
                    </div>
                    <div class="orden-info">
                        <span class="info-label">Cantidad</span>
                        <span class="info-value">5,000 L</span>
                    </div>
                    <div class="orden-info">
                        <span class="info-label">Inicio</span>
                        <span class="info-value">15/01/2024</span>
                    </div>
                </div>
                <div class="orden-footer">
                    <div class="progress-label">Progreso: 65%</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 65%"></div>
                    </div>
                </div>
            </div>
            <div class="orden-card">
                <div class="orden-header">
                    <span class="orden-numero">#ORD-2401-002</span>
                    <span class="pill-amarillo">Planificada</span>
                </div>
                <div class="orden-body">
                    <div class="orden-info">
                        <span class="info-label">Línea</span>
                        <span class="info-value">Línea 2 - Carbonatación</span>
                    </div>
                    <div class="orden-info">
                        <span class="info-label">Cantidad</span>
                        <span class="info-value">3,200 L</span>
                    </div>
                    <div class="orden-info">
                        <span class="info-label">Inicio</span>
                        <span class="info-value">22/01/2024</span>
                    </div>
                </div>
                <div class="orden-footer">
                    <div class="progress-label">Progreso: 0%</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 0%"></div>
                    </div>
                </div>
            </div>
            <div class="orden-card">
                <div class="orden-header">
                    <span class="orden-numero">#ORD-2401-003</span>
                    <span class="pill-rojo">Pausada</span>
                </div>
                <div class="orden-body">
                    <div class="orden-info">
                        <span class="info-label">Línea</span>
                        <span class="info-value">Línea 3 - Embotellado</span>
                    </div>
                    <div class="orden-info">
                        <span class="info-label">Cantidad</span>
                        <span class="info-value">4,500 L</span>
                    </div>
                    <div class="orden-info">
                        <span class="info-label">Inicio</span>
                        <span class="info-value">10/01/2024</span>
                    </div>
                </div>
                <div class="orden-footer">
                    <div class="progress-label">Progreso: 42%</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 42%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Detalle de Receta - Ingredientes -->
    <div class="card">
        <div class="card-header">
            <h2>🧪 Fórmula: <span id="recetaSeleccionada">Refresco Cola v2.1.0</span></h2>
            <button class="btn-agregar" id="btnAgregarIngrediente">+ Agregar Ingrediente</button>
        </div>
        
        <div class="ingredientes-grid">
            <div class="grid-header">
                <div>Ingrediente</div>
                <div>Cantidad</div>
                <div>Unidad</div>
                <div>Orden</div>
                <div></div>
            </div>
            <div id="listaIngredientes">
                <div class="grid-row ingrediente-item">
                    <select class="select-ingrediente" data-field="IngredienteID">
                        <option value="1">Jarabe de Maíz</option>
                        <option value="2">Azúcar Refinada</option>
                        <option value="3">Agua Purificada</option>
                        <option value="4">Gas Carbónico</option>
                    </select>
                    <input type="number" class="input-cantidad" data-field="Cantidad" value="25.5" step="0.1" placeholder="Cantidad">
                    <select class="select-unidad" data-field="UnidadMedidaID">
                        <option value="1">kg</option>
                        <option value="2">L</option>
                        <option value="3">g</option>
                        <option value="4">ml</option>
                    </select>
                    <input type="number" class="input-orden" data-field="OrdenProceso" value="1" placeholder="Orden">
                    <button class="btn-eliminar-fila" title="Eliminar">🗑️</button>
                </div>
                <div class="grid-row ingrediente-item">
                    <select class="select-ingrediente" data-field="IngredienteID">
                        <option value="3">Agua Purificada</option>
                        <option value="4">Gas Carbónico</option>
                        <option value="1">Jarabe de Maíz</option>
                    </select>
                    <input type="number" class="input-cantidad" data-field="Cantidad" value="100.0" step="0.1" placeholder="Cantidad">
                    <select class="select-unidad" data-field="UnidadMedidaID">
                        <option value="2">L</option>
                        <option value="3">g</option>
                        <option value="4">ml</option>
                    </select>
                    <input type="number" class="input-orden" data-field="OrdenProceso" value="2" placeholder="Orden">
                    <button class="btn-eliminar-fila" title="Eliminar">🗑️</button>
                </div>
            </div>
        </div>
        
        <div class="form-actions">
            <button class="btn-secundario" id="btnCancelar">Cancelar</button>
            <button class="btn-rojo" id="btnGuardarReceta">Guardar Fórmula</button>
        </div>
    </div>
</div>

<!-- Modal Nueva Receta -->
<div id="modalNuevaReceta" class="modal">
    <div class="modal-content">
        <span class="modal-close">&times;</span>
        <h3>📝 Nueva Receta</h3>
        <form id="formNuevaReceta">
            <div class="form-group">
                <label>Producto</label>
                <select required>
                    <option>Refresco Cola</option>
                    <option>Naranja Sabor Intenso</option>
                    <option>Lima Limón Zero</option>
                    <option>Manzana Verde</option>
                </select>
            </div>
            <div class="form-group">
                <label>Versión</label>
                <input type="text" value="1.0.0" required>
            </div>
            <div class="form-group">
                <label>Tipo de Receta</label>
                <select>
                    <option>Estándar</option>
                    <option>Premium</option>
                    <option>Light</option>
                </select>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox"> Es Confidencial
                </label>
            </div>
            <button type="submit" class="btn-rojo" style="width: 100%;">Crear Receta</button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/produccionRecetas.js"></script>
}